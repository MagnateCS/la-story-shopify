      "label": "Show measurement icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Modal content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Find your fit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size Guide"
    },
    {
      "type": "richtext",
