{% liquid
  assign modal_id = 'SizeGuideModal-' | append: block.id
  assign title_id = 'SizeGuideTitle-' | append: block.id
  assign chart_id = 'SizeGuideChart-' | append: block.id

  assign selected_scheme_id = block.settings.color_scheme
  assign selected_scheme = settings.color_schemes[selected_scheme_id].settings

  assign scheme_background = selected_scheme.background | default: '#fffaf3'
  assign scheme_heading = selected_scheme.foreground_heading | default: '#3d3028'
  assign scheme_foreground = selected_scheme.foreground | default: '#7a6a5f'
  assign scheme_primary = selected_scheme.primary | default: '#3d3028'
  assign scheme_primary_hover = selected_scheme.primary_hover | default: '#b79a68'
  assign scheme_border = selected_scheme.border | default: '#d8c8b8'
  assign scheme_shadow = selected_scheme.shadow | default: '#cdbcaa'
  assign scheme_input_background = selected_scheme.input_background | default: '#fffaf3'
  assign scheme_input_text = selected_scheme.input_text_color | default: '#3d3028'
  assign scheme_input_border = selected_scheme.input_border_color | default: '#d8c8b8'

  assign has_measurement_image = false
  assign has_uploaded_video = false
  assign has_external_video = false
  assign has_measurement_video = false

  if block.settings.measurement_image != blank
    assign has_measurement_image = true
  endif

  if block.settings.measurement_video != blank
    assign has_uploaded_video = true
    assign has_measurement_video = true
  elsif block.settings.external_video != blank
    assign has_external_video = true
    assign has_measurement_video = true
  endif

  assign has_media = false

  if has_measurement_image or has_measurement_video
    assign has_media = true
  endif
%}

<size-guide-modal
  class="size-guide-block color-{{ block.settings.color_scheme }}"
  data-block-id="{{ block.id }}"
  style="
    --size-guide-background: {{ scheme_background }};
    --size-guide-heading: {{ scheme_heading }};
    --size-guide-foreground: {{ scheme_foreground }};
    --size-guide-primary: {{ scheme_primary }};
    --size-guide-primary-hover: {{ scheme_primary_hover }};
    --size-guide-border: {{ scheme_border }};
    --size-guide-shadow: {{ scheme_shadow }};
    --size-guide-surface: {{ scheme_input_background }};
    --size-guide-surface-text: {{ scheme_input_text }};
    --size-guide-surface-border: {{ scheme_input_border }};

    --size-guide-overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    --size-guide-modal-width: {{ block.settings.modal_width }}px;
    --size-guide-radius: {{ block.settings.border_radius }}px;
    --size-guide-spacing-top: {{ block.settings.spacing_top }}px;
    --size-guide-spacing-bottom: {{ block.settings.spacing_bottom }}px;
  "
  {{ block.shopify_attributes }}
>
  <button
    type="button"
    class="size-guide-block__trigger"
    aria-haspopup="dialog"
    aria-controls="{{ modal_id }}"
    data-size-guide-open
  >
    {% if block.settings.show_trigger_icon %}
      <svg
        class="size-guide-block__trigger-icon"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M3 7.5h18M5 7.5v9h14v-9M8 7.5v3M11 7.5v2M14 7.5v3M17 7.5v2"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    {% endif %}

    <span>{{ block.settings.trigger_text | escape }}</span>
  </button>

  <dialog
    id="{{ modal_id }}"
    class="size-guide-modal color-{{ block.settings.color_scheme }}"
    aria-labelledby="{{ title_id }}"
    data-size-guide-dialog
  >
    <div class="size-guide-modal__shell">
      <header class="size-guide-modal__header">
        <div class="size-guide-modal__heading-group">
          {% if block.settings.eyebrow != blank %}
            <p class="size-guide-modal__eyebrow">
              {{ block.settings.eyebrow | escape }}
            </p>
          {% endif %}

          <h2
            id="{{ title_id }}"
            class="size-guide-modal__title"
          >
            {{ block.settings.heading | escape }}
          </h2>
        </div>

        <button
          type="button"
          class="size-guide-modal__close"
          aria-label="Close size chart"
          data-size-guide-close
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M5 5L19 19M19 5L5 19"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
            />
          </svg>
        </button>
      </header>

      <div class="size-guide-modal__content">
        {% if block.settings.introduction != blank %}
          <div class="size-guide-modal__introduction rte">
            {{ block.settings.introduction }}
          </div>
        {% endif %}

        {% if has_media %}
          <div
            class="
              size-guide-media
              {% if has_measurement_image and has_measurement_video %}
                size-guide-media--two-columns
              {% else %}
                size-guide-media--one-column
              {% endif %}
            "
          >
            {% if has_measurement_image %}
              <section class="size-guide-media__panel">
                {% if block.settings.measurement_heading != blank %}
                  <h3 class="size-guide-media__heading">
                    {{ block.settings.measurement_heading | escape }}
                  </h3>
                {% endif %}

                <div class="size-guide-media__image-wrapper">
                  {{
                    block.settings.measurement_image
                    | image_url: width: 1800
                    | image_tag:
                      class: 'size-guide-media__image',
                      loading: 'lazy',
                      widths: '375, 550, 750, 1000, 1400, 1800',
                      sizes: '(min-width: 990px) 48vw, 100vw',
                      alt: block.settings.measurement_image.alt
                  }}
                </div>
              </section>
            {% endif %}

            {% if has_measurement_video %}
              <section class="size-guide-media__panel">
                {% if block.settings.video_heading != blank %}
                  <h3 class="size-guide-media__heading">
                    {{ block.settings.video_heading | escape }}
                  </h3>
                {% endif %}

                {% if block.settings.video_subheading != blank %}
                  <div class="size-guide-media__subheading rte">
                    {{ block.settings.video_subheading }}
                  </div>
                {% endif %}

                <div class="size-guide-media__video-wrapper">
                  {% if has_uploaded_video %}
                    {{
                      block.settings.measurement_video
                      | video_tag:
                        class: 'size-guide-media__video',
                        image_size: '1200x',
                        controls: true,
                        autoplay: false,
                        loop: false,
                        muted: false,
                        playsinline: true,
                        preload: 'metadata'
                    }}
                  {% elsif has_external_video %}
                    {% if block.settings.external_video.type == 'youtube' %}
                      <iframe
                        class="size-guide-media__iframe"
                        src="https://www.youtube.com/embed/{{ block.settings.external_video.id }}?rel=0"
                        title="{{ block.settings.video_heading | default: 'How to measure' | escape }}"
                        loading="lazy"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                      ></iframe>
                    {% elsif block.settings.external_video.type == 'vimeo' %}
                      <iframe
                        class="size-guide-media__iframe"
                        src="https://player.vimeo.com/video/{{ block.settings.external_video.id }}"
                        title="{{ block.settings.video_heading | default: 'How to measure' | escape }}"
                        loading="lazy"
                        allow="autoplay; fullscreen; picture-in-picture"
                        allowfullscreen
                      ></iframe>
                    {% endif %}
                  {% endif %}
                </div>
              </section>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.show_unit_toggle %}
          <div
            class="size-guide-unit-toggle"
            role="group"
            aria-label="Choose measurement unit"
          >
            <button
              type="button"
              class="size-guide-unit-toggle__label is-active"
              data-size-guide-unit="in"
              aria-pressed="true"
            >
              {{ block.settings.inches_label | escape }}
            </button>

            <button
              type="button"
              class="size-guide-unit-toggle__switch"
              data-size-guide-unit-switch
              aria-label="Switch between inches and centimeters"
            >
              <span class="size-guide-unit-toggle__thumb"></span>
            </button>

            <button
              type="button"
              class="size-guide-unit-toggle__label"
              data-size-guide-unit="cm"
              aria-pressed="false"
            >
              {{ block.settings.centimeters_label | escape }}
            </button>
          </div>
        {% endif %}

        <div
          id="{{ chart_id }}"
          class="size-guide-chart"
          data-size-guide-chart
          data-default-unit="{% if block.settings.default_unit == 'cm' %}cm{% else %}in{% endif %}"
          data-decimal-places="{{ block.settings.decimal_places }}"
        >
          <div class="size-guide-chart__scroll">
            <table class="size-guide-chart__table">
              <caption class="visually-hidden">
                {{ block.settings.heading | escape }}
              </caption>

              <thead data-size-guide-table-head></thead>
              <tbody data-size-guide-table-body></tbody>
            </table>
          </div>
        </div>

        <script
          type="application/json"
          data-size-guide-chart-data
        >
          {
            "rows": {{ block.settings.size_chart_data | newline_to_br | split: '<br />' | json }}
          }
        </script>

        {% if block.settings.custom_size_notice != blank %}
          <div class="size-guide-modal__notice rte">
            {{ block.settings.custom_size_notice }}
          </div>
        {% endif %}

        {% if block.settings.stylist_text != blank %}
          <div class="size-guide-modal__stylist">
            {% if block.settings.stylist_link != blank %}
              <a href="{{ block.settings.stylist_link }}">
                {{ block.settings.stylist_text | escape }}
              </a>
            {% else %}
              <span>{{ block.settings.stylist_text | escape }}</span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </dialog>
</size-guide-modal>

<style>
  .size-guide-block {
    display: block;
    padding-top: var(--size-guide-spacing-top);
    padding-bottom: var(--size-guide-spacing-bottom);
    color: var(--size-guide-foreground);
  }

  .size-guide-block__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0;
    border: 0;
    border-bottom: 1px solid currentColor;
    background: transparent;
    color: var(--size-guide-primary);
    font-family: var(--font-body--family, inherit);
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      color 180ms ease,
      opacity 180ms ease;
  }

  .size-guide-block__trigger:hover {
    color: var(--size-guide-primary-hover);
  }

  .size-guide-block__trigger-icon {
    width: 1.15rem;
    height: 1.15rem;
    flex: 0 0 auto;
  }

  .size-guide-block__trigger:focus-visible,
  .size-guide-modal__close:focus-visible,
  .size-guide-unit-toggle button:focus-visible,
  .size-guide-modal__stylist a:focus-visible {
    outline: 2px solid var(--size-guide-primary-hover);
    outline-offset: 4px;
  }

  .size-guide-modal {
    width: min(
      calc(100% - 2rem),
      var(--size-guide-modal-width)
    );
    max-width: var(--size-guide-modal-width);
    max-height: calc(100dvh - 2rem);
    margin: auto;
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--size-guide-border);
    border-radius: var(--size-guide-radius);
    background: var(--size-guide-background);
    color: var(--size-guide-foreground);
    box-shadow:
      0 30px 90px color-mix(
        in srgb,
        var(--size-guide-shadow) 52%,
        transparent
      );
  }

  .size-guide-modal::backdrop {
    background: rgb(23 18 15 / var(--size-guide-overlay-opacity));
    backdrop-filter: blur(3px);
  }

  .size-guide-modal[open] {
    animation: size-guide-modal-open 240ms ease both;
  }

  .size-guide-modal.is-closing {
    animation: size-guide-modal-close 180ms ease both;
  }

  .size-guide-modal__shell {
    display: flex;
    max-height: calc(100dvh - 2rem);
    flex-direction: column;
    background: var(--size-guide-background);
  }

  .size-guide-modal__header {
    display: flex;
    min-height: 84px;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin: 0 42px;
    padding: 22px 0 14px;
    border-bottom: 1px solid var(--size-guide-border);
  }

  .size-guide-modal__heading-group {
    min-width: 0;
  }

  .size-guide-modal__eyebrow {
    margin: 0 0 4px;
    color: var(--size-guide-primary-hover);
    font-family: var(--font-body--family, inherit);
    font-size: 0.65rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .size-guide-modal__title {
    margin: 0;
    color: var(--size-guide-heading);
    font-family: var(--font-heading--family, "Cormorant Garamond", serif);
    font-size: clamp(1.65rem, 3vw, 2.35rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.025em;
    text-transform: none;
  }

  .size-guide-modal__close {
    display: grid;
    width: 42px;
    height: 42px;
    flex: 0 0 auto;
    place-items: center;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 50%;
    background: transparent;
    color: var(--size-guide-primary);
    cursor: pointer;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease;
  }

  .size-guide-modal__close:hover {
    border-color: var(--size-guide-border);
    background: var(--size-guide-surface);
    color: var(--size-guide-primary-hover);
  }

  .size-guide-modal__close svg {
    width: 22px;
    height: 22px;
  }

  .size-guide-modal__content {
    padding: 28px 42px 40px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .size-guide-modal__introduction {
    max-width: 760px;
    margin: 0 auto 30px;
    color: var(--size-guide-foreground);
    font-family: var(--font-body--family, inherit);
    font-size: 0.9rem;
    line-height: 1.75;
    text-align: center;
  }

  .size-guide-modal__introduction > *:first-child,
  .size-guide-media__subheading > *:first-child,
  .size-guide-modal__notice > *:first-child {
    margin-top: 0;
  }

  .size-guide-modal__introduction > *:last-child,
  .size-guide-media__subheading > *:last-child,
  .size-guide-modal__notice > *:last-child {
    margin-bottom: 0;
  }

  .size-guide-media {
    display: grid;
    align-items: start;
    gap: 34px;
    margin-bottom: 32px;
  }

  .size-guide-media--two-columns {
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
  }

  .size-guide-media--one-column {
    grid-template-columns: minmax(0, 820px);
    justify-content: center;
  }

  .size-guide-media__panel {
    min-width: 0;
  }

  .size-guide-media__heading {
    margin: 0 0 12px;
    color: var(--size-guide-heading);
    font-family: var(--font-heading--family, "Cormorant Garamond", serif);
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.035em;
    text-align: center;
  }

  .size-guide-media__subheading {
    margin: -4px 0 12px;
    color: var(--size-guide-foreground);
    font-family: var(--font-body--family, inherit);
    font-size: 0.75rem;
    line-height: 1.5;
    text-align: center;
  }

  .size-guide-media__subheading a {
    color: var(--size-guide-primary);
    text-decoration-color: var(--size-guide-primary-hover);
    text-underline-offset: 3px;
  }

  .size-guide-media__image-wrapper {
    display: flex;
    width: 100%;
    min-height: 250px;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid var(--size-guide-border);
    background: #ffffff;
  }

  .size-guide-media__image {
    display: block;
    width: 100%;
    height: auto;
    max-height: 460px;
    object-fit: contain;
  }

  .size-guide-media__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--size-guide-border);
    background: var(--size-guide-surface);
    aspect-ratio: 16 / 9;
  }

  .size-guide-media__video,
  .size-guide-media__iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    object-fit: cover;
  }

  .size-guide-unit-toggle {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 2px 0 16px;
  }

  .size-guide-unit-toggle__label {
    padding: 2px 0;
    border: 0;
    background: transparent;
    color: var(--size-guide-foreground);
    font-family: var(--font-body--family, inherit);
    font-size: 0.72rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    opacity: 0.55;
    transition:
      color 180ms ease,
      opacity 180ms ease;
  }

  .size-guide-unit-toggle__label.is-active {
    color: var(--size-guide-primary);
    opacity: 1;
  }

  .size-guide-unit-toggle__switch {
    position: relative;
    width: 38px;
    height: 20px;
    padding: 0;
    border: 1px solid var(--size-guide-border);
    border-radius: 999px;
    background: var(--size-guide-surface);
    cursor: pointer;
  }

  .size-guide-unit-toggle__thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--size-guide-primary);
    box-shadow: 0 1px 3px rgb(0 0 0 / 15%);
    transition:
      background-color 180ms ease,
      transform 180ms ease;
  }

  .size-guide-unit-toggle__switch:hover
    .size-guide-unit-toggle__thumb {
    background: var(--size-guide-primary-hover);
  }

  .size-guide-unit-toggle.is-centimeters
    .size-guide-unit-toggle__thumb {
    transform: translateX(18px);
  }

  .size-guide-chart {
    width: 100%;
  }

  .size-guide-chart__scroll {
    width: 100%;
    overflow-x: auto;
    border-top: 1px solid var(--size-guide-border);
    border-left: 1px solid var(--size-guide-border);
    scrollbar-color:
      var(--size-guide-primary-hover)
      var(--size-guide-surface);
    scrollbar-width: thin;
  }

  .size-guide-chart__table {
    width: 100%;
    min-width: 920px;
    border-spacing: 0;
    border-collapse: separate;
    color: var(--size-guide-surface-text);
    font-family: var(--font-body--family, inherit);
    font-size: 0.74rem;
    line-height: 1.35;
    table-layout: auto;
  }

  .size-guide-chart__table th,
  .size-guide-chart__table td {
    min-width: 49px;
    padding: 11px 10px;
    border-right: 1px solid var(--size-guide-border);
    border-bottom: 1px solid var(--size-guide-border);
    text-align: center;
    white-space: nowrap;
  }

  .size-guide-chart__table thead th {
    background: var(--size-guide-surface);
    color: var(--size-guide-heading);
    font-weight: 400;
  }

  .size-guide-chart__table tbody td {
    background: var(--size-guide-background);
    color: var(--size-guide-foreground);
  }

  .size-guide-chart__table thead th:first-child,
  .size-guide-chart__table tbody th {
    position: sticky;
    left: 0;
    z-index: 2;
    min-width: 180px;
    background: var(--size-guide-surface);
    color: var(--size-guide-heading);
    font-weight: 400;
  }

  .size-guide-chart__table thead th:first-child {
    z-index: 3;
  }

  .size-guide-modal__notice {
    margin-top: 20px;
    padding: 16px 18px;
    border: 1px solid var(--size-guide-border);
    background: var(--size-guide-surface);
    color: var(--size-guide-foreground);
    font-family: var(--font-body--family, inherit);
    font-size: 0.78rem;
    line-height: 1.65;
  }

  .size-guide-modal__notice strong {
    color: var(--size-guide-heading);
    font-weight: 500;
  }

  .size-guide-modal__stylist {
    margin-top: 12px;
    color: var(--size-guide-foreground);
    font-family: var(--font-body--family, inherit);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  .size-guide-modal__stylist a {
    color: var(--size-guide-primary);
    text-decoration-color: var(--size-guide-primary-hover);
    text-underline-offset: 4px;
    transition: color 180ms ease;
  }

  .size-guide-modal__stylist a:hover {
    color: var(--size-guide-primary-hover);
  }

  body.size-guide-modal-open {
    overflow: hidden;
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  @keyframes size-guide-modal-open {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.99);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes size-guide-modal-close {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    to {
      opacity: 0;
      transform: translateY(10px) scale(0.99);
    }
  }

  @media screen and (max-width: 989px) {
    .size-guide-media--two-columns {
      grid-template-columns: 1fr;
    }

    .size-guide-media__image {
      max-height: 560px;
    }
  }

  @media screen and (max-width: 749px) {
    .size-guide-modal {
      width: calc(100% - 12px);
      max-height: calc(100dvh - 12px);
      border-radius: min(var(--size-guide-radius), 10px);
    }

    .size-guide-modal__shell {
      max-height: calc(100dvh - 12px);
    }

    .size-guide-modal__header {
      min-height: 68px;
      margin: 0 18px;
      padding: 15px 0 11px;
    }

    .size-guide-modal__title {
      font-size: 1.55rem;
    }

    .size-guide-modal__content {
      padding: 22px 18px 30px;
    }

    .size-guide-modal__introduction {
      margin-bottom: 24px;
      font-size: 0.82rem;
    }

    .size-guide-media {
      gap: 26px;
      margin-bottom: 26px;
    }

    .size-guide-media__image-wrapper {
      min-height: 180px;
    }

    .size-guide-media__image {
      max-height: 430px;
    }

    .size-guide-chart__table {
      min-width: 840px;
    }

    .size-guide-chart__table thead th:first-child,
    .size-guide-chart__table tbody th {
      min-width: 142px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .size-guide-modal[open],
    .size-guide-modal.is-closing {
      animation: none;
    }

    .size-guide-unit-toggle__thumb,
    .size-guide-block__trigger,
    .size-guide-modal__close {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    if (customElements.get('size-guide-modal')) return;

    class SizeGuideModal extends HTMLElement {
      constructor() {
        super();

        this.dialog = null;
        this.openButton = null;
        this.closeButton = null;
        this.unitToggle = null;
        this.unitButtons = [];
        this.unitSwitch = null;
        this.chart = null;
        this.chartDataElement = null;
        this.tableHead = null;
        this.tableBody = null;
        this.chartRows = [];
        this.currentUnit = 'in';
        this.closeTimer = null;

        this.handleOpen = this.handleOpen.bind(this);
        this.handleClose = this.handleClose.bind(this);
        this.handleDialogClick = this.handleDialogClick.bind(this);
        this.handleDialogCancel = this.handleDialogCancel.bind(this);
        this.handleUnitClick = this.handleUnitClick.bind(this);
        this.handleSwitchClick = this.handleSwitchClick.bind(this);
      }

      connectedCallback() {
        this.dialog = this.querySelector('[data-size-guide-dialog]');
        this.openButton = this.querySelector('[data-size-guide-open]');
        this.closeButton = this.querySelector('[data-size-guide-close]');
        this.unitToggle = this.querySelector('.size-guide-unit-toggle');

        this.unitButtons = Array.from(
          this.querySelectorAll('[data-size-guide-unit]')
        );

        this.unitSwitch = this.querySelector(
          '[data-size-guide-unit-switch]'
        );

        this.chart = this.querySelector('[data-size-guide-chart]');

        this.chartDataElement = this.querySelector(
          '[data-size-guide-chart-data]'
        );

        this.tableHead = this.querySelector(
          '[data-size-guide-table-head]'
        );

        this.tableBody = this.querySelector(
          '[data-size-guide-table-body]'
        );

        if (!this.dialog || !this.openButton) return;

        this.openButton.addEventListener('click', this.handleOpen);
        this.closeButton?.addEventListener('click', this.handleClose);
        this.dialog.addEventListener('click', this.handleDialogClick);
        this.dialog.addEventListener('cancel', this.handleDialogCancel);

        this.unitButtons.forEach((button) => {
          button.addEventListener('click', this.handleUnitClick);
        });

        this.unitSwitch?.addEventListener(
          'click',
          this.handleSwitchClick
        );

        this.parseChartData();

        const defaultUnit =
          this.chart?.dataset.defaultUnit === 'cm'
            ? 'cm'
            : 'in';

        this.setUnit(defaultUnit);
      }

      disconnectedCallback() {
        this.openButton?.removeEventListener(
          'click',
          this.handleOpen
        );

        this.closeButton?.removeEventListener(
          'click',
          this.handleClose
        );

        this.dialog?.removeEventListener(
          'click',
          this.handleDialogClick
        );

        this.dialog?.removeEventListener(
          'cancel',
          this.handleDialogCancel
        );

        this.unitButtons.forEach((button) => {
          button.removeEventListener(
            'click',
            this.handleUnitClick
          );
        });

        this.unitSwitch?.removeEventListener(
          'click',
          this.handleSwitchClick
        );

        window.clearTimeout(this.closeTimer);
      }

      parseChartData() {
        if (!this.chartDataElement) return;

        try {
          const parsedData = JSON.parse(
            this.chartDataElement.textContent.trim()
          );

          this.chartRows = (parsedData.rows || [])
            .map((row) => String(row).trim())
            .filter(Boolean)
            .map((row) => {
              return row
                .split('|')
                .map((cell) => cell.trim());
            });
        } catch (error) {
          console.error(
            'Unable to parse size chart data.',
            error
          );

          this.chartRows = [];
        }
      }

      renderTable() {
        if (
          !this.tableHead ||
          !this.tableBody ||
          this.chartRows.length === 0
        ) {
          return;
        }

        const headerRow = this.chartRows[0];
        const measurementRows = this.chartRows.slice(1);

        this.tableHead.innerHTML = '';
        this.tableBody.innerHTML = '';

        const headRowElement = document.createElement('tr');

        headerRow.forEach((cell) => {
          const heading = document.createElement('th');
          heading.scope = 'col';
          heading.textContent = cell;
          headRowElement.appendChild(heading);
        });

        this.tableHead.appendChild(headRowElement);

        measurementRows.forEach((row) => {
          if (!row.length) return;

          const rowElement = document.createElement('tr');

          row.forEach((cell, index) => {
            if (index === 0) {
              const heading = document.createElement('th');
              heading.scope = 'row';
              heading.textContent =
                this.formatMeasurementLabel(cell);

              rowElement.appendChild(heading);
              return;
            }

            const tableCell = document.createElement('td');
            tableCell.textContent =
              this.formatMeasurementValue(cell);

            rowElement.appendChild(tableCell);
          });

          this.tableBody.appendChild(rowElement);
        });
      }

      formatMeasurementLabel(label) {
        const cleanLabel = String(label)
          .replace(/\s*\((IN|CM)\)\s*/gi, '')
          .trim();

        const unitLabel =
          this.currentUnit === 'cm'
            ? 'CM'
            : 'IN';

        return `${cleanLabel} (${unitLabel})`;
      }

      formatMeasurementValue(value) {
        const numericValue = Number.parseFloat(value);

        if (!Number.isFinite(numericValue)) {
          return value;
        }

        if (this.currentUnit === 'in') {
          return this.removeUnnecessaryZeros(numericValue);
        }

        const decimalPlaces = Number.parseInt(
          this.chart?.dataset.decimalPlaces || '1',
          10
        );

        const centimeters = numericValue * 2.54;

        return centimeters.toFixed(decimalPlaces);
      }

      removeUnnecessaryZeros(value) {
        if (Number.isInteger(value)) {
          return value.toFixed(1);
        }

        return String(value);
      }

      setUnit(unit) {
        this.currentUnit =
          unit === 'cm'
            ? 'cm'
            : 'in';

        this.unitButtons.forEach((button) => {
          const isActive =
            button.dataset.sizeGuideUnit ===
            this.currentUnit;

          button.classList.toggle(
            'is-active',
            isActive
          );

          button.setAttribute(
            'aria-pressed',
            isActive ? 'true' : 'false'
          );
        });

        this.unitToggle?.classList.toggle(
          'is-centimeters',
          this.currentUnit === 'cm'
        );

        this.renderTable();
      }

      handleUnitClick(event) {
        const selectedUnit =
          event.currentTarget.dataset.sizeGuideUnit;

        this.setUnit(selectedUnit);
      }

      handleSwitchClick() {
        this.setUnit(
          this.currentUnit === 'in'
            ? 'cm'
            : 'in'
        );
      }

      handleOpen() {
        if (
          !this.dialog ||
          typeof this.dialog.showModal !== 'function'
        ) {
          return;
        }

        window.clearTimeout(this.closeTimer);
        this.dialog.classList.remove('is-closing');

        if (!this.dialog.open) {
          this.dialog.showModal();
        }

        document.body.classList.add(
          'size-guide-modal-open'
        );

        requestAnimationFrame(() => {
          this.closeButton?.focus();
        });
      }

      handleClose() {
        if (!this.dialog?.open) return;

        this.dialog.classList.add('is-closing');

        this.closeTimer = window.setTimeout(() => {
          this.dialog.classList.remove('is-closing');
          this.dialog.close();

          document.body.classList.remove(
            'size-guide-modal-open'
          );

          this.openButton?.focus();
        }, 180);
      }

      handleDialogClick(event) {
        if (event.target === this.dialog) {
          this.handleClose();
        }
      }

      handleDialogCancel(event) {
        event.preventDefault();
        this.handleClose();
      }
    }

    customElements.define(
      'size-guide-modal',
      SizeGuideModal
    );
  })();
</script>

