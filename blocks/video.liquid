{% assign block_settings = block.settings %}

{% capture video_style %}
  {% render 'spacing-style', settings: block_settings %}
  {% render 'border-override', settings: block_settings %}
  --size-style-width: {{ block_settings.custom_width }}%;
  --size-style-width-mobile: {{ block_settings.custom_width_mobile }}%;
  --size-style-aspect-ratio: {% if block_settings.source == 'uploaded' %}{{ block_settings.video.aspect_ratio | default: 'auto' }}{% elsif block_settings.cover_image == blank %}{{ block_settings.aspect_ratio }}{% else %}auto{% endif %};
{% endcapture %}

<div
  class="
    video-overlay-block
    video-overlay-block--{{ block.id }}
    {% unless block_settings.show_video_controls %}
      video-overlay-block--hide-controls
    {% endunless %}
  "
  {{ block.shopify_attributes }}
>
  <div class="video-overlay-block__media">
    {% if block_settings.source == 'uploaded' %}
      {% render 'video',
        video: block_settings.video,
        video_class: 'spacing-style size-style border-style',
        video_loop: block_settings.video_loop,
        video_autoplay: block_settings.video_autoplay,
        video_controls: block_settings.show_video_controls,
        video_style: video_style,
        video_preview_image: block_settings.video.preview_image
      %}
    {% else %}
      {% render 'video',
        video_from_url: true,
        video: block_settings.video_url.id,
        video_class: 'spacing-style size-style border-style',
        video_type: block_settings.video_url.type,
        video_autoplay: block_settings.video_autoplay,
        video_controls: block_settings.show_video_controls,
        video_style: video_style,
        video_alt: block_settings.alt,
        video_preview_image: block_settings.cover_image
      %}
    {% endif %}
  </div>

  {% if block_settings.enable_overlay_text and block_settings.overlay_text != blank %}
    <div
      class="
        video-overlay-block__content
        video-overlay-block__content--horizontal-{{ block_settings.overlay_horizontal_position }}
        video-overlay-block__content--vertical-{{ block_settings.overlay_vertical_position }}
      "
      aria-hidden="false"
    >
      <div class="video-overlay-block__text">
        {{ block_settings.overlay_text }}
      </div>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .placeholder-video {
    aspect-ratio: 5 / 3;
  }

  .video-overlay-block {
    position: relative;
    width: fit-content;
    max-width: 100%;
  }

  .video-overlay-block__media {
    position: relative;
    z-index: 1;
  }

  .video-overlay-block__media video,
  .video-overlay-block__media iframe,
  .video-overlay-block__media img,
  .video-overlay-block__media .video,
  .video-overlay-block__media .video-wrapper,
  .video-overlay-block__media deferred-media {
    display: block;
  }

  .video-overlay-block__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    pointer-events: none;
    padding: var(--video-overlay-padding-desktop, 24px);
  }

  .video-overlay-block__content--horizontal-left {
    justify-content: flex-start;
  }

  .video-overlay-block__content--horizontal-center {
    justify-content: center;
  }

  .video-overlay-block__content--horizontal-right {
    justify-content: flex-end;
  }

  .video-overlay-block__content--vertical-top {
    align-items: flex-start;
  }

  .video-overlay-block__content--vertical-center {
    align-items: center;
  }

  .video-overlay-block__content--vertical-bottom {
    align-items: flex-end;
  }

  .video-overlay-block__text {
    pointer-events: auto;
    width: var(--video-overlay-text-width, fit-content);
    max-width: var(--video-overlay-text-max-width, 80%);
    color: var(--video-overlay-text-color, currentColor);
    font-family: var(--video-overlay-font-family, var(--font-heading--family));
    font-size: var(--video-overlay-font-size-desktop, 2rem);
    font-weight: var(--video-overlay-font-weight, 400);
    line-height: var(--video-overlay-line-height, 1.1);
    letter-spacing: var(--video-overlay-letter-spacing, normal);
    text-align: var(--video-overlay-text-align, center);
    text-transform: var(--video-overlay-text-transform, none);
    text-shadow: var(--video-overlay-text-shadow, none);
    background: var(--video-overlay-background, transparent);
    border-radius: var(--video-overlay-corner-radius, 0px);
    padding: var(--video-overlay-box-padding, 0px);
  }

  .video-overlay-block__text > * {
    margin-block-start: 0;
    margin-block-end: 0;
  }

  .video-overlay-block__text > * + * {
    margin-block-start: 0.5em;
  }

  /*
    Fallback helper:
    This visually hides controls in some browsers/theme wrappers,
    but the main control logic is handled by video_controls above.
  */
  .video-overlay-block--hide-controls video::-webkit-media-controls {
    display: none !important;
  }

  .video-overlay-block--hide-controls video::-webkit-media-controls-enclosure {
    display: none !important;
  }

  @media screen and (max-width: 749px) {
    .video-overlay-block__content {
      padding: var(--video-overlay-padding-mobile, 16px);
    }

    .video-overlay-block__text {
      max-width: var(--video-overlay-text-max-width-mobile, 90%);
      font-size: var(--video-overlay-font-size-mobile, 1.5rem);
    }
  }
{% endstylesheet %}

<style>
  .video-overlay-block--{{ block.id }} {
    width: {{ block_settings.custom_width }}%;
  }

  .video-overlay-block--{{ block.id }} {
    --video-overlay-padding-desktop: {{ block_settings.overlay_padding_desktop }}px;
    --video-overlay-padding-mobile: {{ block_settings.overlay_padding_mobile }}px;
    --video-overlay-text-width: {{ block_settings.overlay_text_width }};
    --video-overlay-text-max-width: {{ block_settings.overlay_text_max_width }}%;
    --video-overlay-text-max-width-mobile: {{ block_settings.overlay_text_max_width_mobile }}%;
    --video-overlay-text-align: {{ block_settings.overlay_text_alignment }};
    --video-overlay-font-family: {{ block_settings.overlay_font }};
    --video-overlay-font-size-desktop: {{ block_settings.overlay_font_size_desktop | divided_by: 16.0 }}rem;
    --video-overlay-font-size-mobile: {{ block_settings.overlay_font_size_mobile | divided_by: 16.0 }}rem;
    --video-overlay-font-weight: {{ block_settings.overlay_font_weight }};
    --video-overlay-line-height: {{ block_settings.overlay_line_height }};
    --video-overlay-letter-spacing: {{ block_settings.overlay_letter_spacing | divided_by: 100.0 }}em;
    --video-overlay-text-transform: {{ block_settings.overlay_text_transform }};

    {% unless block_settings.overlay_text_color.alpha == 0.0 %}
      --video-overlay-text-color: {{ block_settings.overlay_text_color }};
    {% endunless %}

    {% if block_settings.enable_text_shadow %}
      --video-overlay-text-shadow: 0 {{ block_settings.text_shadow_y }}px {{ block_settings.text_shadow_blur }}px rgba(0, 0, 0, {{ block_settings.text_shadow_opacity | divided_by: 100.0 }});
    {% endif %}

    {% if block_settings.enable_text_background %}
      --video-overlay-background: {{ block_settings.text_background_color }};
      --video-overlay-corner-radius: {{ block_settings.text_background_radius }}px;
      --video-overlay-box-padding: {{ block_settings.text_background_padding_vertical }}px {{ block_settings.text_background_padding_horizontal }}px;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .video-overlay-block--{{ block.id }} {
      width: {{ block_settings.custom_width_mobile }}%;
    }
  }
</style>

{% schema %}
{
