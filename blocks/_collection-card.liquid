{% assign collection = closest.collection %}
{% assign block_settings = block.settings %}

{% capture card_image %}
  {% content_for 'block',
    type: '_collection-card-image',
    id: 'collection-card-image',
    closest.collection: collection,
    parent_block_id: block.id %}
{% endcapture %}

{% capture empty_children %}
{% endcapture %}

<div
  class="
    editorial-collection-card
    editorial-collection-card--{{ block.id }}
    {% if block_settings.enable_image_zoom %}editorial-collection-card--image-zoom{% endif %}
  "
  style="
    --editorial-card-height: {{ block_settings.card_height | default: 620 }}px;
    --editorial-card-radius: {{ block_settings.border_radius | default: 0 }}px;
    --editorial-overlay-opacity: {{ block_settings.overlay_opacity | default: 34 | divided_by: 100.0 }};
    --editorial-title-color: {{ block_settings.title_color | default: '#FFFFFF' }};
    --editorial-button-color: {{ block_settings.button_color | default: '#FFFFFF' }};
    --editorial-title-size: {{ block_settings.title_size | default: 22 }}px;
    --editorial-button-size: {{ block_settings.button_size | default: 11 }}px;
    --editorial-content-bottom: {{ block_settings.content_bottom_spacing | default: 64 }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="editorial-collection-card__inner">
    {% render 'collection-card',
      card_image: card_image,
      children: empty_children,
      block: block,
      collection: collection,
      section: section
    %}

    {% if collection != blank %}
      <a
        href="{{ collection.url }}"
        class="editorial-collection-card__full-link"
        aria-label="Explore {{ collection.title | escape }}"
      ></a>

      <div class="editorial-collection-card__content">
        <h3 class="editorial-collection-card__title">
          {{ collection.title }}
        </h3>

        <a
          href="{{ collection.url }}"
          class="editorial-collection-card__explore"
          aria-label="Explore {{ collection.title | escape }}"
        >
          <span>Explore</span>
          <span class="editorial-collection-card__arrow">›</span>
        </a>
      </div>
    {% else %}
      <div class="editorial-collection-card__content">
        <h3 class="editorial-collection-card__title">
          Collection
        </h3>

        <span class="editorial-collection-card__explore">
          <span>Explore</span>
          <span class="editorial-collection-card__arrow">›</span>
        </span>
      </div>
    {% endif %}
  </div>
</div>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&display=swap');

  .editorial-collection-card--{{ block.id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: var(--editorial-card-height);
    isolation: isolate;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner {
    position: relative !important;
    width: 100%;
    height: var(--editorial-card-height) !important;
    min-height: var(--editorial-card-height) !important;
    overflow: hidden !important;
    border: none !important;
    border-radius: var(--editorial-card-radius);
    background: transparent !important;
    box-shadow: none !important;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, calc(var(--editorial-overlay-opacity) * 0.12)) 48%,
        rgba(0, 0, 0, var(--editorial-overlay-opacity)) 100%
      );
  }

  .editorial-collection-card--{{ block.id }} .collection-card {
    position: relative !important;
    width: 100%;
    height: 100% !important;
    min-height: 100% !important;
    overflow: hidden !important;
    border: none !important;
    border-radius: var(--editorial-card-radius);
    background: transparent !important;
    box-shadow: none !important;
  }

  .editorial-collection-card--{{ block.id }} .collection-card img,
  .editorial-collection-card--{{ block.id }} .collection-card picture,
  .editorial-collection-card--{{ block.id }} .collection-card video {
    width: 100% !important;
    height: 100% !important;
    min-height: 100% !important;
    object-fit: cover !important;
    display: block;
    transition:
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 900ms ease;
  }

  .editorial-collection-card--{{ block.id }} .collection-card img {
    filter: saturate(0.96) contrast(1.02);
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__full-link {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: block;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__content {
    position: absolute !important;
    left: 50% !important;
    bottom: var(--editorial-content-bottom) !important;
    z-index: 10 !important;
    width: min(88%, 420px);
    height: auto !important;
    min-height: 0 !important;
    transform: translateX(-50%);
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 0 !important;
    margin: 0 !important;
    text-align: center;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    overflow: visible !important;
    pointer-events: none;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__title {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    position: relative !important;
    z-index: 11 !important;
    width: auto !important;
    height: auto !important;
    min-height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    font-family: "Playfair Display", Georgia, serif !important;
    font-size: var(--editorial-title-size) !important;
    font-weight: 400 !important;
    line-height: 1.1 !important;
    letter-spacing: -0.025em !important;
    color: var(--editorial-title-color) !important;
    text-align: center !important;
    text-transform: none !important;
    text-shadow: 0 8px 28px rgba(0, 0, 0, 0.34);
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    overflow: visible !important;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore {
    position: relative;
    z-index: 11;
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: auto;
    height: auto !important;
    min-height: auto !important;
    padding: 0 0 5px !important;
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    color: var(--editorial-button-color) !important;
    box-shadow: none !important;
    font-size: var(--editorial-button-size) !important;
    font-weight: 500 !important;
    line-height: 1.2 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    text-shadow: 0 8px 22px rgba(0, 0, 0, 0.3);
    pointer-events: auto;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: calc(100% - 18px);
    height: 1px;
    background: currentColor;
    opacity: 0.78;
    transform-origin: left;
    transition:
      transform 360ms ease,
      opacity 360ms ease;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__arrow {
    display: inline-block;
    font-size: 1.2em;
    line-height: 1;
    transform: translateY(-1px);
    transition: transform 360ms ease;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore:hover::after {
    transform: scaleX(0.72);
    opacity: 1;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore:hover .editorial-collection-card__arrow {
    transform: translate(4px, -1px);
  }

  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover .collection-card img,
  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover .collection-card picture,
  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover .collection-card video {
    transform: scale(1.035);
    filter: saturate(1.02) contrast(1.05);
  }

  @media screen and (max-width: 749px) {
    .editorial-collection-card--{{ block.id }},
    .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner {
      height: 460px !important;
      min-height: 460px !important;
    }

    .editorial-collection-card--{{ block.id }} .editorial-collection-card__title {
      font-size: calc(var(--editorial-title-size) * 0.9) !important;
    }

    .editorial-collection-card--{{ block.id }} .editorial-collection-card__content {
      bottom: max(calc(var(--editorial-content-bottom) * 0.7), 36px) !important;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:names.collection_card",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_collection_card"
    },
    {
      "type": "header",
      "content": "Editorial Collection Card"
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height",
      "min": 320,
      "max": 820,
      "step": 20,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "content_bottom_spacing",
      "label": "Text bottom spacing",
      "min": 16,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom overlay strength",
      "min": 0,
      "max": 75,
      "step": 1,
      "unit": "%",
      "default": 34
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Collection name size",
      "min": 16,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Explore button size",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "checkbox",
      "id": "enable_image_zoom",
      "label": "Enable subtle image zoom",
      "default": true
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Collection name color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Explore button color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}