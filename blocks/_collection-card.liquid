{% assign collection = closest.collection %}
{% assign block_settings = block.settings %}

{% capture card_image %}
  {% content_for 'block',
    type: '_collection-card-image',
    id: 'collection-card-image',
    closest.collection: collection,
    parent_block_id: block.id %}
{% endcapture %}

{% capture children %}
  <div class="editorial-collection-card__content">
    {% if collection != blank %}
      <h3 class="editorial-collection-card__title">
        {{ collection.title }}
      </h3>

      <a
        href="{{ collection.url }}"
        class="editorial-collection-card__explore"
        aria-label="Explore {{ collection.title }}"
      >
        <span>Explore</span>
        <span class="editorial-collection-card__arrow">›</span>
      </a>
    {% endif %}
  </div>
{% endcapture %}

<div
  class="
    editorial-collection-card
    editorial-collection-card--{{ block.id }}
    {% if block_settings.enable_image_zoom %}editorial-collection-card--image-zoom{% endif %}
  "
  style="
    --editorial-card-height: {{ block_settings.card_height }}px;
    --editorial-card-radius: {{ block_settings.border_radius }}px;
    --editorial-overlay-opacity: {{ block_settings.overlay_opacity | divided_by: 100.0 }};
    --editorial-title-color: {{ block_settings.title_color }};
    --editorial-button-color: {{ block_settings.button_color }};
    --editorial-title-size: {{ block_settings.title_size }}px;
    --editorial-button-size: {{ block_settings.button_size }}px;
    --editorial-content-bottom: {{ block_settings.content_bottom_spacing }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="editorial-collection-card__inner">
    {% render 'collection-card',
      card_image: card_image,
      children: children,
      block: block,
      collection: collection,
      section: section
    %}
  </div>
</div>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&display=swap');

  .editorial-collection-card--{{ block.id }} {
    position: relative;
    width: 100%;
    height: 100%;
    isolation: isolate;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner {
    position: relative;
    overflow: hidden;
    min-height: var(--editorial-card-height);
    height: 100%;
    border: none;
    border-radius: var(--editorial-card-radius);
    background: transparent;
    box-shadow: none;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, calc(var(--editorial-overlay-opacity) * 0.12)) 45%,
        rgba(0, 0, 0, var(--editorial-overlay-opacity)) 100%
      );
  }

  .editorial-collection-card--{{ block.id }} .collection-card,
  .editorial-collection-card--{{ block.id }} [class*="collection-card"] {
    position: relative;
    min-height: var(--editorial-card-height);
    height: 100%;
    overflow: hidden;
    border: none !important;
    border-radius: var(--editorial-card-radius);
    background: transparent !important;
    box-shadow: none !important;
  }

  .editorial-collection-card--{{ block.id }} img,
  .editorial-collection-card--{{ block.id }} picture,
  .editorial-collection-card--{{ block.id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 900ms ease;
  }

  .editorial-collection-card--{{ block.id }} img {
    filter: saturate(0.96) contrast(1.02);
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__content {
    position: absolute;
    left: 50%;
    bottom: var(--editorial-content-bottom);
    z-index: 5;
    width: min(88%, 420px);
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 0;
    margin: 0;
    text-align: center;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__title {
    margin: 0;
    padding: 0;
    font-family: "Playfair Display", Georgia, serif;
    font-size: var(--editorial-title-size);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--editorial-title-color);
    text-align: center;
    text-transform: none;
    text-shadow: 0 8px 28px rgba(0, 0, 0, 0.34);
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: auto;
    min-height: auto;
    padding: 0 0 5px;
    margin: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    color: var(--editorial-button-color);
    box-shadow: none;
    font-size: var(--editorial-button-size);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    text-shadow: 0 8px 22px rgba(0, 0, 0, 0.3);
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: calc(100% - 18px);
    height: 1px;
    background: currentColor;
    opacity: 0.78;
    transform-origin: left;
    transition:
      transform 360ms ease,
      opacity 360ms ease;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__arrow {
    display: inline-block;
    font-size: 1.2em;
    line-height: 1;
    transform: translateY(-1px);
    transition: transform 360ms ease;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore:hover::after {
    transform: scaleX(0.72);
    opacity: 1;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore:hover .editorial-collection-card__arrow {
    transform: translate(4px, -1px);
  }

  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover img,
  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover picture,
  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover video {
    transform: scale(1.035);
    filter: saturate(1.02) contrast(1.05);
  }

  @media screen and (max-width: 989px) {
    .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner,
    .editorial-collection-card--{{ block.id }} .collection-card,
    .editorial-collection-card--{{ block.id }} [class*="collection-card"] {
      min-height: min(var(--editorial-card-height), 520px);
    }
  }

  @media screen and (max-width: 749px) {
    .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner,
    .editorial-collection-card--{{ block.id }} .collection-card,
    .editorial-collection-card--{{ block.id }} [class*="collection-card"] {
      min-height: 460px;
    }

    .editorial-collection-card--{{ block.id }} .editorial-collection-card__title {
      font-size: calc(var(--editorial-title-size) * 0.88);
    }

    .editorial-collection-card--{{ block.id }} .editorial-collection-card__content {
      bottom: max(calc(var(--editorial-content-bottom) * 0.7), 36px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .editorial-collection-card--{{ block.id }} img,
    .editorial-collection-card--{{ block.id }} picture,
    .editorial-collection-card--{{ block.id }} video,
    .editorial-collection-card--{{ block.id }} .editorial-collection-card__arrow,
    .editorial-collection-card--{{ block.id }} .editorial-collection-card__explore::after {
      transition: none;
    }

    .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover img,
    .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover picture,
    .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover video {
      transform: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:names.collection_card",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_collection_card"
    },
    {
      "type": "header",
      "content": "Editorial Collection Card"
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height",
      "min": 320,
      "max": 820,
      "step": 20,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "content_bottom_spacing",
      "label": "Text bottom spacing",
      "min": 24,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom overlay strength",
      "min": 0,
      "max": 75,
      "step": 1,
      "unit": "%",
      "default": 34
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Collection name size",
      "min": 16,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Explore button size",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "checkbox",
      "id": "enable_image_zoom",
      "label": "Enable subtle image zoom",
      "default": true
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Collection name color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Explore button color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}