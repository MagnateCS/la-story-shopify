{% assign collection = closest.collection %}

{% capture card_image %}
  {% content_for 'block',
    type: '_collection-card-image',
    id: 'collection-card-image',
    closest.collection: collection,
    parent_block_id: block.id %}
{% endcapture %}

{% capture children %}
  {% if block.settings.enable_luxury_overlay and block.settings.placement == 'on_image' %}
    <div
      class="
        collection-card-luxury-overlay
        collection-card-luxury-overlay--{{ block.id }}
        collection-card-luxury-overlay--{{ block.settings.overlay_direction }}
      "
      aria-hidden="true"
    ></div>
  {% endif %}

  <div class="collection-card-luxury-content collection-card-luxury-content--{{ block.id }}">
    {% content_for 'blocks', closest.collection: collection %}
  </div>
{% endcapture %}

{% render 'collection-card',
  card_image: card_image,
  children: children,
  block: block,
  collection: collection,
  section: section
%}

<style>
  /*
    Safer overlay version:
    - Does not wrap the image
    - Does not change image sizing, cropping, aspect ratio, or object-fit
    - Overlay is added to the card content layer only
  */

  .collection-card-luxury-overlay--{{ block.id }} {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .collection-card-luxury-content--{{ block.id }} {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .collection-card-luxury-overlay--{{ block.id }}.collection-card-luxury-overlay--top-to-bottom {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, {{ block.settings.overlay_top_opacity | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_mid_opacity | divided_by: 100.0 }}) 48%,
      rgba(0, 0, 0, {{ block.settings.overlay_bottom_opacity | divided_by: 100.0 }}) 100%
    );
  }

  .collection-card-luxury-overlay--{{ block.id }}.collection-card-luxury-overlay--bottom-to-top {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, {{ block.settings.overlay_top_opacity | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_mid_opacity | divided_by: 100.0 }}) 48%,
      rgba(0, 0, 0, {{ block.settings.overlay_bottom_opacity | divided_by: 100.0 }}) 100%
    );
  }

  .collection-card-luxury-overlay--{{ block.id }}.collection-card-luxury-overlay--center-vignette {
    background: radial-gradient(
      circle at center,
      rgba(0, 0, 0, {{ block.settings.overlay_top_opacity | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_mid_opacity | divided_by: 100.0 }}) 52%,
      rgba(0, 0, 0, {{ block.settings.overlay_bottom_opacity | divided_by: 100.0 }}) 100%
    );
  }

  .collection-card-luxury-overlay--{{ block.id }}.collection-card-luxury-overlay--full {
    background: rgba(
      0,
      0,
      0,
      {{ block.settings.overlay_bottom_opacity | divided_by: 100.0 }}
    );
  }
</style>

{% schema %}
{
  "name": "t:names.collection_card",
  "blocks": [
    {
      "type": "text"
    },
    {
      "type": "spacer"
    },
    {
      "type": "button"
    },
    {
      "type": "group"
    },
    {
      "type": "collection-title"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_collection_card"
    },
    {
      "type": "header",
      "content": "t:content.text"
    },
    {
      "type": "select",
      "id": "placement",
      "label": "t:settings.placement",
      "options": [
        {
          "value": "on_image",
          "label": "t:options.on_image"
        },
        {
          "value": "below_image",
          "label": "t:options.below_image"
        }
      ]
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "center",
      "visible_if": "{{ block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "range",
      "id": "collection_card_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Luxury overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_luxury_overlay",
      "label": "Enable luxury overlay",
      "default": false,
      "visible_if": "{{ block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "select",
      "id": "overlay_direction",
      "label": "Overlay style",
      "default": "top-to-bottom",
      "options": [
        {
          "value": "top-to-bottom",
          "label": "Faded top to deeper bottom"
        },
        {
          "value": "bottom-to-top",
          "label": "Faded bottom to deeper top"
        },
        {
          "value": "center-vignette",
          "label": "Soft vignette"
        },
        {
          "value": "full",
          "label": "Full soft overlay"
        }
      ],
      "visible_if": "{{ block.settings.enable_luxury_overlay == true and block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "range",
      "id": "overlay_top_opacity",
      "label": "Lightest overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0,
      "visible_if": "{{ block.settings.enable_luxury_overlay == true and block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "range",
      "id": "overlay_mid_opacity",
      "label": "Middle overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 15,
      "visible_if": "{{ block.settings.enable_luxury_overlay == true and block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "range",
      "id": "overlay_bottom_opacity",
      "label": "Deepest overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 55,
      "visible_if": "{{ block.settings.enable_luxury_overlay == true and block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.borders",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "t:settings.border_width",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.border_opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}