{% liquid
  assign block_settings = block.settings
%}

<div
  class="
    collection-title-wrapper
    collection-title-wrapper--{{ block.id }}
    {% if block_settings.enable_luxury_overlay %}collection-title-wrapper--has-overlay{% endif %}
  "
>
  {% if block_settings.enable_luxury_overlay %}
    <div
      class="
        luxury-text-overlay
        luxury-text-overlay--{{ block.id }}
        luxury-text-overlay--{{ block_settings.overlay_direction }}
      "
      aria-hidden="true"
    ></div>
  {% endif %}

  <div class="collection-title-content collection-title-content--{{ block.id }}">
    {% if closest.collection == blank %}
      {% assign text = 'placeholders.collection_title' | t %}
      {% assign collection_title = '<p>' | append: text | append: '</p>' %}
      {% render 'text', fallback_text: collection_title, block: block %}
    {% elsif closest.collection != blank %}
      {% assign collection_title = '<p>' | append: closest.collection.title | append: '</p>' %}
      {% render 'text', fallback_text: collection_title, block: block %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .collection-title-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .collection-title-content {
    position: relative;
    z-index: 2;
  }

  .luxury-text-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .luxury-text-overlay--top-to-bottom {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, var(--luxury-overlay-mid-opacity, 0.18)) 48%,
      rgba(0, 0, 0, var(--luxury-overlay-bottom-opacity, 0.55)) 100%
    );
  }

  .luxury-text-overlay--bottom-to-top {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, var(--luxury-overlay-mid-opacity, 0.18)) 48%,
      rgba(0, 0, 0, var(--luxury-overlay-bottom-opacity, 0.55)) 100%
    );
  }

  .luxury-text-overlay--full {
    background: rgba(
      0,
      0,
      0,
      var(--luxury-overlay-bottom-opacity, 0.35)
    );
  }
{% endstylesheet %}

<style>
  .luxury-text-overlay--{{ block.id }} {
    --luxury-overlay-mid-opacity: {{ block_settings.overlay_mid_opacity | divided_by: 100.0 }};
    --luxury-overlay-bottom-opacity: {{ block_settings.overlay_bottom_opacity | divided_by: 100.0 }};
  }
</style>

{% schema %}
{
  "name": "t:names.collection_title",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_collection_title"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "checkbox",
      "id": "enable_luxury_overlay",
      "label": "Enable luxury text overlay",
      "default": false
    },
    {
      "type": "select",
      "id": "overlay_direction",
      "label": "Overlay direction",
      "default": "top-to-bottom",
      "options": [
        {
          "value": "top-to-bottom",
          "label": "Faded top to deeper bottom"
        },
        {
          "value": "bottom-to-top",
          "label": "Faded bottom to deeper top"
        },
        {
          "value": "full",
          "label": "Full soft overlay"
        }
      ]
    },
    {
      "type": "range",
      "id": "overlay_mid_opacity",
      "label": "Middle overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 15
    },
    {
      "type": "range",
      "id": "overlay_bottom_opacity",
      "label": "Deepest overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 55
    }
  ],
  "presets": [
    {
      "name": "t:names.collection_title"
    }
  ]
}
{% endschema %}