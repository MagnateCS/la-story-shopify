{% assign collection = closest.collection %}
{% assign block_settings = block.settings %}

{% capture card_image %}
  {% content_for 'block',
    type: '_collection-card-image',
    id: 'collection-card-image',
    closest.collection: collection,
    parent_block_id: block.id %}
{% endcapture %}

{% capture children %}
  {% content_for 'blocks', closest.collection: collection %}
{% endcapture %}

<div
  class="
    editorial-collection-card
    editorial-collection-card--{{ block.id }}
    editorial-collection-card--placement-{{ block_settings.placement }}
    {% if block_settings.enable_image_zoom %}editorial-collection-card--image-zoom{% endif %}
  "
  style="
    --editorial-card-height: {{ block_settings.card_height }}px;
    --editorial-card-radius: {{ block_settings.border_radius }}px;
    --editorial-overlay-opacity: {{ block_settings.overlay_opacity | divided_by: 100.0 }};
    --editorial-title-color: {{ block_settings.title_color }};
    --editorial-text-color: {{ block_settings.text_color }};
    --editorial-title-size: {{ block_settings.title_size }}px;
    --editorial-link-size: {{ block_settings.link_size }}px;
    --editorial-content-bottom: {{ block_settings.content_bottom_spacing }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="editorial-collection-card__inner">
    {% render 'collection-card',
      card_image: card_image,
      children: children,
      block: block,
      collection: collection,
      section: section
    %}
  </div>
</div>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&display=swap');

  .editorial-collection-card--{{ block.id }} {
    position: relative;
    width: 100%;
    height: 100%;
    isolation: isolate;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner {
    position: relative;
    overflow: hidden;
    min-height: var(--editorial-card-height);
    height: 100%;
    border: none;
    border-radius: var(--editorial-card-radius);
    background: transparent;
    box-shadow: none;
  }

  .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, calc(var(--editorial-overlay-opacity) * 0.18)) 48%,
        rgba(0, 0, 0, var(--editorial-overlay-opacity)) 100%
      );
  }

  .editorial-collection-card--{{ block.id }} .collection-card,
  .editorial-collection-card--{{ block.id }} [class*="collection-card"] {
    min-height: var(--editorial-card-height);
    height: 100%;
    border: none !important;
    border-radius: var(--editorial-card-radius);
    background: transparent !important;
    box-shadow: none !important;
    overflow: hidden;
  }

  .editorial-collection-card--{{ block.id }} img,
  .editorial-collection-card--{{ block.id }} picture,
  .editorial-collection-card--{{ block.id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 900ms ease;
  }

  .editorial-collection-card--{{ block.id }} img {
    filter: saturate(0.96) contrast(1.02);
  }

  .editorial-collection-card--{{ block.id }} :is(
    .collection-card__content,
    [class*="collection-card"] [class*="content"]
  ) {
    position: absolute !important;
    left: 50% !important;
    right: auto !important;
    bottom: var(--editorial-content-bottom) !important;
    z-index: 5 !important;
    width: min(88%, 420px);
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center !important;
    justify-content: center;
    gap: 10px;
    padding: 0 !important;
    margin: 0 !important;
    text-align: center !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
  }

  .editorial-collection-card--{{ block.id }} :is(
    h1,
    h2,
    h3,
    h4,
    h5,
    h6,
    .collection-title,
    [class*="title"]
  ) {
    margin: 0 !important;
    padding: 0 !important;
    font-family: "Playfair Display", Georgia, serif !important;
    font-size: var(--editorial-title-size) !important;
    font-weight: 400 !important;
    line-height: 1.1 !important;
    letter-spacing: -0.025em !important;
    color: var(--editorial-title-color) !important;
    text-align: center !important;
    text-transform: none !important;
    text-shadow: 0 8px 28px rgba(0, 0, 0, 0.32);
    background: transparent !important;
    box-shadow: none !important;
  }

  .editorial-collection-card--{{ block.id }} :is(
    p,
    span,
    .text-block,
    [class*="text"]
  ) {
    margin: 0 !important;
    color: var(--editorial-text-color) !important;
    background: transparent !important;
    box-shadow: none !important;
    text-align: center !important;
  }

  .editorial-collection-card--{{ block.id }} :is(
    a,
    button,
    .button
  ) {
    position: relative;
    z-index: 6;
    min-height: auto !important;
    padding: 0 0 4px !important;
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    color: var(--editorial-text-color) !important;
    box-shadow: none !important;
    font-size: var(--editorial-link-size) !important;
    font-weight: 500 !important;
    line-height: 1.2 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
  }

  .editorial-collection-card--{{ block.id }} :is(
    a,
    button,
    .button
  )::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: calc(100% - 18px);
    height: 1px;
    background: currentColor;
    opacity: 0.75;
    transform-origin: left;
    transition: transform 360ms ease, opacity 360ms ease;
  }

  .editorial-collection-card--{{ block.id }} :is(
    a,
    button,
    .button
  ):hover::after {
    transform: scaleX(0.72);
    opacity: 1;
  }

  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover img,
  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover picture,
  .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover video {
    transform: scale(1.035);
    filter: saturate(1.02) contrast(1.05);
  }

  @media screen and (max-width: 989px) {
    .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner,
    .editorial-collection-card--{{ block.id }} .collection-card,
    .editorial-collection-card--{{ block.id }} [class*="collection-card"] {
      min-height: min(var(--editorial-card-height), 520px);
    }
  }

  @media screen and (max-width: 749px) {
    .editorial-collection-card--{{ block.id }} .editorial-collection-card__inner,
    .editorial-collection-card--{{ block.id }} .collection-card,
    .editorial-collection-card--{{ block.id }} [class*="collection-card"] {
      min-height: 460px;
    }

    .editorial-collection-card--{{ block.id }} :is(
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      .collection-title,
      [class*="title"]
    ) {
      font-size: calc(var(--editorial-title-size) * 0.82) !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .editorial-collection-card--{{ block.id }} img,
    .editorial-collection-card--{{ block.id }} picture,
    .editorial-collection-card--{{ block.id }} video {
      transition: none;
    }

    .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover img,
    .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover picture,
    .editorial-collection-card--{{ block.id }}.editorial-collection-card--image-zoom:hover video {
      transform: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:names.collection_card",
  "blocks": [
    {
      "type": "text"
    },
    {
      "type": "spacer"
    },
    {
      "type": "button"
    },
    {
      "type": "group"
    },
    {
      "type": "collection-title"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_collection_card"
    },
    {
      "type": "header",
      "content": "Editorial Luxury Style"
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height",
      "min": 320,
      "max": 820,
      "step": 20,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "content_bottom_spacing",
      "label": "Text bottom spacing",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom overlay strength",
      "min": 0,
      "max": 70,
      "step": 1,
      "unit": "%",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 18,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "link_size",
      "label": "Link size",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "checkbox",
      "id": "enable_image_zoom",
      "label": "Enable subtle image zoom",
      "default": true
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text / link color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "t:content.text"
    },
    {
      "type": "select",
      "id": "placement",
      "label": "t:settings.placement",
      "options": [
        {
          "value": "on_image",
          "label": "t:options.on_image"
        },
        {
          "value": "below_image",
          "label": "t:options.below_image"
        }
      ],
      "default": "on_image"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "flex-end",
      "visible_if": "{{ block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "range",
      "id": "collection_card_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.borders",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "t:settings.border_width",
      "default": 0,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.border_opacity",
      "default": 0,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}