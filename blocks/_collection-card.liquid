{% assign collection = closest.collection %}
{% assign block_settings = block.settings %}

{% capture card_image %}
  {% content_for 'block',
    type: '_collection-card-image',
    id: 'collection-card-image',
    closest.collection: collection,
    parent_block_id: block.id %}
{% endcapture %}

{% capture children %}
  {% content_for 'blocks', closest.collection: collection %}
{% endcapture %}

<div
  class="
    luxury-collection-card
    luxury-collection-card--{{ block.id }}
    luxury-collection-card--placement-{{ block_settings.placement }}
    {% if block_settings.enable_hover_lift %}luxury-collection-card--hover-lift{% endif %}
    {% if block_settings.enable_image_zoom %}luxury-collection-card--image-zoom{% endif %}
  "
  style="
    --luxury-card-radius: {{ block_settings.border_radius }}px;
    --luxury-card-min-height: {{ block_settings.card_min_height }}px;
    --luxury-overlay-opacity: {{ block_settings.overlay_opacity | divided_by: 100.0 }};
    --luxury-content-gap: {{ block_settings.collection_card_gap }}px;
    --luxury-title-color: {{ block_settings.title_color }};
    --luxury-subtle-color: {{ block_settings.subtle_text_color }};
    --luxury-title-size: {{ block_settings.title_size }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="luxury-collection-card__inner">
    {% render 'collection-card',
      card_image: card_image,
      children: children,
      block: block,
      collection: collection,
      section: section
    %}
  </div>
</div>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&display=swap');

  .luxury-collection-card--{{ block.id }} {
    position: relative;
    width: 100%;
    isolation: isolate;
  }

  .luxury-collection-card--{{ block.id }} .luxury-collection-card__inner {
    position: relative;
    overflow: hidden;
    min-height: var(--luxury-card-min-height);
    border-radius: var(--luxury-card-radius);
    background: transparent;
    border: none;
    box-shadow: none;
    transition:
      transform 420ms ease,
      filter 420ms ease;
  }

  .luxury-collection-card--{{ block.id }} .luxury-collection-card__inner::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.02) 0%,
        rgba(0, 0, 0, calc(var(--luxury-overlay-opacity) * 0.35)) 55%,
        rgba(0, 0, 0, var(--luxury-overlay-opacity)) 100%
      );
    opacity: 1;
    transition: opacity 420ms ease;
  }

  .luxury-collection-card--{{ block.id }} .collection-card,
  .luxury-collection-card--{{ block.id }} [class*="collection-card"] {
    min-height: var(--luxury-card-min-height);
    border: none !important;
    box-shadow: none !important;
    background: transparent !important;
  }

  .luxury-collection-card--{{ block.id }} img,
  .luxury-collection-card--{{ block.id }} picture,
  .luxury-collection-card--{{ block.id }} video {
    transition:
      transform 800ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 800ms ease;
  }

  .luxury-collection-card--{{ block.id }} img {
    filter: saturate(0.96) contrast(1.02);
  }

  .luxury-collection-card--{{ block.id }} :is(
    h1,
    h2,
    h3,
    h4,
    h5,
    h6,
    .collection-title,
    [class*="title"]
  ) {
    font-family: "Playfair Display", Georgia, serif !important;
    color: var(--luxury-title-color) !important;
    font-size: var(--luxury-title-size);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.025em;
    text-transform: none;
    text-wrap: balance;
    text-shadow: 0 12px 32px rgba(0, 0, 0, 0.28);
  }

  .luxury-collection-card--{{ block.id }} :is(
    p,
    span,
    .text-block,
    [class*="text"]
  ) {
    color: var(--luxury-subtle-color) !important;
    background: transparent !important;
    box-shadow: none !important;
  }

  .luxury-collection-card--{{ block.id }} :is(
    .collection-card__content,
    [class*="collection-card"] [class*="content"]
  ) {
    position: relative;
    z-index: 5;
    gap: var(--luxury-content-gap);
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: clamp(18px, 4vw, 38px) !important;
  }

  .luxury-collection-card--{{ block.id }} :is(
    .group-block,
    .text-block,
    .button,
    button,
    a
  ) {
    background: transparent;
    box-shadow: none;
  }

  .luxury-collection-card--{{ block.id }} :is(a, button, .button) {
    position: relative;
    z-index: 6;
  }

  .luxury-collection-card--{{ block.id }}.luxury-collection-card--hover-lift:hover .luxury-collection-card__inner {
    transform: translateY(-4px);
  }

  .luxury-collection-card--{{ block.id }}.luxury-collection-card--image-zoom:hover img,
  .luxury-collection-card--{{ block.id }}.luxury-collection-card--image-zoom:hover picture,
  .luxury-collection-card--{{ block.id }}.luxury-collection-card--image-zoom:hover video {
    transform: scale(1.035);
    filter: saturate(1.02) contrast(1.05);
  }

  .luxury-collection-card--{{ block.id }}:hover .luxury-collection-card__inner::before {
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .luxury-collection-card--{{ block.id }} .luxury-collection-card__inner {
      min-height: max(calc(var(--luxury-card-min-height) * 0.82), 280px);
    }

    .luxury-collection-card--{{ block.id }} :is(
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      .collection-title,
      [class*="title"]
    ) {
      font-size: calc(var(--luxury-title-size) * 0.78);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .luxury-collection-card--{{ block.id }} .luxury-collection-card__inner,
    .luxury-collection-card--{{ block.id }} img,
    .luxury-collection-card--{{ block.id }} picture,
    .luxury-collection-card--{{ block.id }} video {
      transition: none;
    }

    .luxury-collection-card--{{ block.id }}.luxury-collection-card--hover-lift:hover .luxury-collection-card__inner,
    .luxury-collection-card--{{ block.id }}.luxury-collection-card--image-zoom:hover img,
    .luxury-collection-card--{{ block.id }}.luxury-collection-card--image-zoom:hover picture,
    .luxury-collection-card--{{ block.id }}.luxury-collection-card--image-zoom:hover video {
      transform: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:names.collection_card",
  "blocks": [
    {
      "type": "text"
    },
    {
      "type": "spacer"
    },
    {
      "type": "button"
    },
    {
      "type": "group"
    },
    {
      "type": "collection-title"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_collection_card"
    },
    {
      "type": "header",
      "content": "Luxury Styling"
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Card minimum height",
      "min": 240,
      "max": 720,
      "step": 20,
      "unit": "px",
      "default": 460
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay strength",
      "min": 0,
      "max": 75,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 24,
      "max": 82,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "checkbox",
      "id": "enable_hover_lift",
      "label": "Enable subtle hover lift",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_image_zoom",
      "label": "Enable image zoom",
      "default": true
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "subtle_text_color",
      "label": "Text color",
      "default": "#F6F0E8"
    },
    {
      "type": "header",
      "content": "t:content.text"
    },
    {
      "type": "select",
      "id": "placement",
      "label": "t:settings.placement",
      "options": [
        {
          "value": "on_image",
          "label": "t:options.on_image"
        },
        {
          "value": "below_image",
          "label": "t:options.below_image"
        }
      ],
      "default": "on_image"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "flex-end",
      "visible_if": "{{ block.settings.placement == \"on_image\" }}"
    },
    {
      "type": "range",
      "id": "collection_card_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.borders",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "t:settings.border_width",
      "default": 0,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.border_opacity",
      "default": 0,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}