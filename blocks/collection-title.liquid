{% liquid
  assign block_settings = block.settings

  if closest.collection == blank
    assign title_text = 'placeholders.collection_title' | t
  else
    assign title_text = closest.collection.title
  endif
%}

<div
  class="
    collection-title-custom
    collection-title-custom--{{ block.id }}
    {% if block_settings.background %}collection-title-custom--has-background{% endif %}
    {% if block_settings.enable_text_shadow %}collection-title-custom--shadow{% endif %}
  "
  style="
    --collection-title-width: {{ block_settings.width }};
    --collection-title-max-width: {{ block_settings.max_width }};
    --collection-title-alignment: {{ block_settings.alignment }};
    --collection-title-font-family: {{ block_settings.font }};
    --collection-title-size: {{ block_settings.font_size }}px;
    --collection-title-size-mobile: {{ block_settings.font_size_mobile }}px;
    --collection-title-weight: {{ block_settings.font_weight }};
    --collection-title-line-height: {{ block_settings.line_height }};
    --collection-title-letter-spacing: {{ block_settings.letter_spacing }}em;
    --collection-title-mobile-letter-spacing: {{ block_settings.mobile_letter_spacing }}em;
    --collection-title-case: {{ block_settings.case }};
    --collection-title-color: {{ block_settings.color }};
    --collection-title-background: {{ block_settings.background_color }};
    --collection-title-radius: {{ block_settings.corner_radius }}px;
    --collection-title-shadow-opacity: {{ block_settings.text_shadow_opacity | divided_by: 100.0 }};
    --collection-title-padding-top: {{ block_settings.padding-block-start }}px;
    --collection-title-padding-bottom: {{ block_settings.padding-block-end }}px;
    --collection-title-padding-left: {{ block_settings.padding-inline-start }}px;
    --collection-title-padding-right: {{ block_settings.padding-inline-end }}px;
  "
  {{ block.shopify_attributes }}
>
  <p class="collection-title-custom__text">
    {{ title_text }}
  </p>
</div>

{% style %}
  .collection-title-custom--{{ block.id }} {
    width: var(--collection-title-width);
    max-width:
      {% case block_settings.max_width %}
        {% when 'narrow' %}
          420px
        {% when 'normal' %}
          720px
        {% else %}
          none
      {% endcase %};
    text-align: var(--collection-title-alignment);
    padding:
      var(--collection-title-padding-top)
      var(--collection-title-padding-right)
      var(--collection-title-padding-bottom)
      var(--collection-title-padding-left);
    border-radius: var(--collection-title-radius);
    background: transparent;
  }

  .collection-title-custom--{{ block.id }}.collection-title-custom--has-background {
    background: var(--collection-title-background);
  }

  .collection-title-custom--{{ block.id }} .collection-title-custom__text {
    margin: 0;
    padding: 0;
    font-family: var(--collection-title-font-family);
    font-size: var(--collection-title-size);
    font-weight: var(--collection-title-weight);
    line-height: var(--collection-title-line-height);
    letter-spacing: var(--collection-title-letter-spacing);
    text-transform: var(--collection-title-case);
    color: var(--collection-title-color);
    text-align: inherit;
    text-wrap: {{ block_settings.wrap }};
  }

  .collection-title-custom--{{ block.id }}.collection-title-custom--shadow .collection-title-custom__text {
    text-shadow: 0 8px 28px rgba(0, 0, 0, var(--collection-title-shadow-opacity));
  }

  @media screen and (max-width: 749px) {
    .collection-title-custom--{{ block.id }} {
      width: 100%;
      max-width: 100%;
      text-align: {{ block_settings.mobile_alignment }};
    }

    .collection-title-custom--{{ block.id }} .collection-title-custom__text {
      font-size: var(--collection-title-size-mobile);
      line-height: {{ block_settings.mobile_line_height }};
      letter-spacing: var(--collection-title-mobile-letter-spacing);
    }
  }
{% endstyle %}

