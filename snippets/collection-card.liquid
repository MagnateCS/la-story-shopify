{%- doc -%}
  This snippet is used to render a collection card.
  To be used inside a block to inherit the block object settings.

  @param {string} card_image - The image to display in the collection card
  @param {string} children - The content to render inside the collection card
  @param {object} collection - The collection to render the card for
  @param {object} block - The block object
  @param {object} section - The section object

  @example
  {% render 'collection-card',
    card_image: card_image,
    children: children,
    block: block,
    collection: collection,
    section: section
  %}
{%- enddoc -%}

{% style %}
  {% if request.visual_preview_mode %}
    .collection-card {
      min-width: 250px;
    }
  {% endif %}
{% endstyle %}

{% liquid
  assign onboarding = false
  assign block_settings = block.settings

  if collection == blank
    assign onboarding = true
  endif
%}

<div
  class="
    collection-card
    border-style
    {% if block_settings.placement == 'on_image' %}collection-card--image-bg{% endif %}
    {% if section.settings.layout_type == 'bento' %}collection-card--image-height-fixed{% endif %}
    {% if section.settings.layout_type == 'editorial' %}collection-card--flexible-aspect-ratio{% endif %}
    {% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}
  "
  data-block-id="{{ block.id }}"
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
  style="
    {% render 'border-override', settings: block_settings %}
    --horizontal-alignment: {{ block_settings.horizontal_alignment | default: 'center' }};
    --vertical-alignment: {{ block_settings.vertical_alignment | default: 'flex-end' }};
    --background-overlay-color: {{ block_settings.overlay_color | default: '#00000000' }};
    --gap: {{ block_settings.collection_card_gap | default: 0 }}px;
  "
  {{- block.shopify_attributes -}}
>
  <a
    class="collection-card__link"
    {% unless onboarding %}
      href="{{ collection.url }}"
    {% endunless %}
  >
    <span class="visually-hidden">
      {% if collection != blank %}
        {{ collection.title }}
      {% else %}
        Collection
      {% endif %}
    </span>
  </a>

  <div class="collection-card__inner">
    {{ card_image }}

    {% if children != blank %}
      <div class="collection-card__content layout-panel-flex--column">
        {{ children }}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .collection-card {
    --fixed-card-height: var(--height-small);

    position: relative;
    flex: 1 1 var(--card-width-small);
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .collection-card > svg {
    height: 100%;
    width: 100%;
    aspect-ratio: var(--ratio);
  }

  .collection-card__link {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: block;
  }

  .collection-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: inherit;
    gap: var(--gap);
    overflow: hidden;
  }

  .collection-card__inner a,
  .collection-card__inner button {
    pointer-events: auto;
  }

  .shopify-design-mode .collection-card__content * {
    pointer-events: auto;
  }

  .collection-card__content {
    position: relative;
    z-index: 3;
    max-width: 100%;
    --flex-wrap: wrap;
  }

  .collection-card--image-bg .collection-card__inner {
    height: 100%;
  }

  .collection-card.collection-card--image-bg {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .collection-card--image-height-fixed {
    height: 100%;
  }

  .collection-card--image-height-fixed .collection-card__image {
    height: var(--fixed-card-height);
    width: 100%;
  }

  .collection-card--image-height-fixed.collection-card--image-bg {
    height: var(--fixed-card-height);
    aspect-ratio: unset;
  }

  .collection-card__image {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .collection-card__image .image-block__image {
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: inherit;
  }

  .collection-card--image-bg .collection-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .collection-card__image svg {
    height: 100%;
    width: 100%;
  }

  /*
    Important:
    Do not force aspect-ratio here.
    The custom editorial collection card controls height, mobile height,
    image fit, and object positioning from _collection-card.liquid.
  */

  .editorial-collection-card .collection-card {
    height: 100% !important;
    min-height: 100% !important;
    aspect-ratio: auto !important;
  }

  .editorial-collection-card .collection-card__inner {
    height: 100% !important;
    min-height: 100% !important;
    aspect-ratio: auto !important;
  }

  .editorial-collection-card .collection-card__image {
    position: absolute;
    inset: 0;
    height: 100% !important;
    min-height: 100% !important;
    aspect-ratio: auto !important;
  }

  .editorial-collection-card .collection-card__image img,
  .editorial-collection-card .collection-card__image .image-block__image {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important;
    object-position: center top !important;
  }

  @media screen and (max-width: 749px) {
    .editorial-collection-card .collection-card,
    .editorial-collection-card .collection-card__inner,
    .editorial-collection-card .collection-card__image {
      height: 100% !important;
      min-height: 100% !important;
      aspect-ratio: auto !important;
    }

    .editorial-collection-card .collection-card__image img,
    .editorial-collection-card .collection-card__image .image-block__image {
      object-fit: contain !important;
      object-position: center top !important;
    }
  }
{% endstylesheet %}