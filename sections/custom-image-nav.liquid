{% comment %}
  Luxury Brand Navigation
  /sections/luxury-brand-nav.liquid

  Each block = one brand tab with optional icon, label, link, and submenu.
  Submenu items are pulled from a Shopify navigation menu (Admin > Navigation).
  The brand wordmark on the left is controlled via section settings.
{% endcomment %}

{%- liquid
  assign ss = section.settings
-%}

<header class="lbn lbn--{{ section.id }}" role="banner">
  <div class="lbn__bar">

    {%- comment %} ── Brand wordmark ── {% endcomment %}
    <a class="lbn__brand" href="{{ ss.brand_link | default: '/' }}" aria-label="{{ ss.brand_name | escape }}">
      {%- if ss.brand_logo != blank -%}
        {{
          ss.brand_logo
          | image_url: width: 300
          | image_tag:
            class: 'lbn__brand-logo',
            widths: '150, 200, 300',
            alt: ss.brand_name | escape
        }}
      {%- else -%}
        <span class="lbn__brand-name">{{ ss.brand_name | upcase }}</span>
      {%- endif -%}
    </a>

    {%- comment %} ── Rule between brand and tabs ── {% endcomment %}
    <div class="lbn__rule" aria-hidden="true"></div>

    {%- comment %} ── Brand tabs ── {% endcomment %}
    <nav class="lbn__nav" aria-label="Brand collections">
      <ul class="lbn__tabs" role="list">
        {%- for block in section.blocks -%}
          {%- assign bs = block.settings -%}

          {%- assign menu_links = linklists[bs.menu].links -%}
          {%- assign has_sub = false -%}
          {%- if menu_links.size > 0 -%}{%- assign has_sub = true -%}{%- endif -%}

          <li
            class="lbn__tab{% if has_sub %} lbn__tab--has-sub{% endif %}"
            {{ block.shopify_attributes }}
          >
            <a
              class="lbn__tab-link"
              href="{{ bs.link | default: '#' }}"
              {% if has_sub %}aria-haspopup="true" aria-expanded="false"{% endif %}
            >
              {%- if bs.icon != blank -%}
                <span class="lbn__icon" aria-hidden="true">
                  {{-
                    bs.icon
                    | image_url: width: 80
                    | image_tag:
                      class: 'lbn__icon-img',
                      widths: '40, 60, 80',
                      loading: 'lazy',
                      alt: ''
                  -}}
                </span>
                <span class="lbn__tab-divider" aria-hidden="true"></span>
              {%- endif -%}
              <span class="lbn__tab-label">{{ bs.label | upcase }}</span>
            </a>

            {%- if has_sub -%}
              <div class="lbn__dropdown" role="navigation" aria-label="{{ bs.label }} menu">
                <ul class="lbn__sub-list" role="list">
                  {%- for link in menu_links -%}
                    <li class="lbn__sub-item">
                      <a class="lbn__sub-link" href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
                <div class="lbn__dropdown-rule" aria-hidden="true"></div>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

  </div>
</header>

<script>
  (function () {
    const header = document.querySelector('.lbn--{{ section.id }}');
    if (!header) return;

    const tabs = header.querySelectorAll('.lbn__tab--has-sub');

    tabs.forEach(function (tab) {
      const link = tab.querySelector('.lbn__tab-link');
      const dropdown = tab.querySelector('.lbn__dropdown');

      function open() {
        tab.classList.add('is-open');
        link.setAttribute('aria-expanded', 'true');
      }

      function close() {
        tab.classList.remove('is-open');
        link.setAttribute('aria-expanded', 'false');
      }

      tab.addEventListener('mouseenter', open);
      tab.addEventListener('mouseleave', close);

      // Keyboard accessibility
      link.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          tab.classList.contains('is-open') ? close() : open();
        }
        if (e.key === 'Escape') close();
      });

      dropdown.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { close(); link.focus(); }
      });
    });
  })();
</script>

{% style %}

  /* ─────────────────────────────────────────
     Tokens
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} {
    --lbn-bg:           {{ ss.background_color }};
    --lbn-text:         {{ ss.text_color }};
    --lbn-accent:       {{ ss.accent_color }};
    --lbn-rule:         {{ ss.rule_color }};
    --lbn-drop-bg:      {{ ss.dropdown_bg }};
    --lbn-drop-text:    {{ ss.dropdown_text_color }};
    --lbn-height:       {{ ss.nav_height }}px;
    --lbn-drop-height:  {{ ss.dropdown_height }}px;
    --lbn-brand-size:   {{ ss.brand_font_size }}px;
    --lbn-label-size:   {{ ss.label_font_size }}px;
    --lbn-sub-size:     {{ ss.sub_font_size }}px;
    --lbn-tracking:     {{ ss.letter_spacing | divided_by: 1000.0 }}em;
    --lbn-sub-tracking: {{ ss.sub_letter_spacing | divided_by: 1000.0 }}em;
    --lbn-gap:          {{ ss.tab_gap }}px;
    --lbn-ease:         cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* ─────────────────────────────────────────
     Shell
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} {
    position: relative;
    width: 100%;
    background: var(--lbn-bg);
    border-bottom: 1px solid var(--lbn-rule);
    z-index: 100;
  }

  .lbn--{{ section.id }} .lbn__bar {
    display: flex;
    align-items: center;
    height: var(--lbn-height);
    max-width: {{ ss.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ ss.side_padding }}px;
    gap: 0;
  }

  /* ─────────────────────────────────────────
     Brand
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} .lbn__brand {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
    color: var(--lbn-text);
  }

  .lbn--{{ section.id }} .lbn__brand-logo {
    display: block;
    height: {{ ss.brand_logo_height }}px;
    width: auto;
  }

  .lbn--{{ section.id }} .lbn__brand-name {
    font-family: {{ ss.brand_font }};
    font-size: var(--lbn-brand-size);
    font-weight: {{ ss.brand_font_weight }};
    letter-spacing: var(--lbn-tracking);
    color: var(--lbn-text);
    white-space: nowrap;
  }

  /* ─────────────────────────────────────────
     Vertical rule between brand & nav
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} .lbn__rule {
    width: 1px;
    height: {{ ss.rule_height }}px;
    background: var(--lbn-rule);
    flex-shrink: 0;
    margin: 0 {{ ss.rule_margin }}px;
  }

  /* ─────────────────────────────────────────
     Tabs list
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} .lbn__tabs {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--lbn-gap);
    height: 100%;
  }

  /* ─────────────────────────────────────────
     Individual tab
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} .lbn__tab {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .lbn--{{ section.id }} .lbn__tab-link {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 100%;
    text-decoration: none;
    color: var(--lbn-text);
    position: relative;
    padding: 0 4px;
  }

  /* Bottom accent line — hidden by default */
  .lbn--{{ section.id }} .lbn__tab-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--lbn-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s var(--lbn-ease);
  }

  .lbn--{{ section.id }} .lbn__tab:hover .lbn__tab-link::after,
  .lbn--{{ section.id }} .lbn__tab.is-open .lbn__tab-link::after {
    transform: scaleX(1);
  }

  /* ─────────────────────────────────────────
     Icon
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} .lbn__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .lbn--{{ section.id }} .lbn__icon-img {
    display: block;
    height: {{ ss.icon_height }}px;
    width: auto;
    opacity: 0.9;
    transition: opacity 0.25s ease;
  }

  .lbn--{{ section.id }} .lbn__tab-link:hover .lbn__icon-img {
    opacity: 1;
  }

  /* Thin vertical rule between icon and label */
  .lbn--{{ section.id }} .lbn__tab-divider {
    display: block;
    width: 1px;
    height: {{ ss.icon_height | times: 0.7 | round }}px;
    background: var(--lbn-rule);
    flex-shrink: 0;
    margin: 0 2px;
  }

  /* ─────────────────────────────────────────
     Tab label
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} .lbn__tab-label {
    font-family: {{ ss.label_font }};
    font-size: var(--lbn-label-size);
    font-weight: {{ ss.label_font_weight }};
    letter-spacing: var(--lbn-tracking);
    color: inherit;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .lbn--{{ section.id }} .lbn__tab:hover .lbn__tab-label,
  .lbn--{{ section.id }} .lbn__tab.is-open .lbn__tab-label {
    color: var(--lbn-accent);
  }

  /* ─────────────────────────────────────────
     Dropdown
  ───────────────────────────────────────── */
  .lbn--{{ section.id }} .lbn__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: max-content;
    background: var(--lbn-drop-bg);
    border-top: 1px solid var(--lbn-accent);
    padding: 24px 32px 20px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.3s var(--lbn-ease),
      transform 0.3s var(--lbn-ease),
      visibility 0s 0.3s;
    transform: translateX(-50%) translateY(-6px);
    z-index: 200;
  }

  .lbn--{{ section.id }} .lbn__tab.is-open .lbn__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
    transition:
      opacity 0.3s var(--lbn-ease),
      transform 0.3s var(--lbn-ease),
      visibility 0s 0s;
  }

  .lbn--{{ section.id }} .lbn__sub-list {
    display: flex;
    align-items: center;
    gap: {{ ss.sub_gap }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .lbn--{{ section.id }} .lbn__sub-link {
    display: block;
    font-family: {{ ss.sub_font }};
    font-size: var(--lbn-sub-size);
    font-weight: {{ ss.sub_font_weight }};
    letter-spacing: var(--lbn-sub-tracking);
    text-transform: {{ ss.sub_case }};
    color: var(--lbn-drop-text);
    text-decoration: none;
    padding: 4px 0;
    position: relative;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .lbn--{{ section.id }} .lbn__sub-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--lbn-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.25s var(--lbn-ease);
  }

  .lbn--{{ section.id }} .lbn__sub-link:hover {
    color: var(--lbn-accent);
  }

  .lbn--{{ section.id }} .lbn__sub-link:hover::after {
    transform: scaleX(1);
  }

  /* Thin rule below sub-links */
  .lbn--{{ section.id }} .lbn__dropdown-rule {
    height: 1px;
    background: var(--lbn-rule);
    margin-top: 20px;
    opacity: 0.4;
  }

  /* ─────────────────────────────────────────
     Mobile — collapse to a simple row
  ───────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .lbn--{{ section.id }} .lbn__bar {
      flex-direction: column;
      height: auto;
      padding: 16px {{ ss.side_padding }}px;
      gap: 12px;
    }

    .lbn--{{ section.id }} .lbn__rule {
      display: none;
    }

    .lbn--{{ section.id }} .lbn__tabs {
      flex-wrap: wrap;
      justify-content: center;
      height: auto;
      gap: 16px;
    }

    .lbn--{{ section.id }} .lbn__tab {
      height: auto;
    }

    .lbn--{{ section.id }} .lbn__tab-link {
      height: auto;
      padding: 8px 0;
    }

    .lbn--{{ section.id }} .lbn__dropdown {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      border-top: none;
      padding: 8px 0 0;
      min-width: unset;
    }

    .lbn--{{ section.id }} .lbn__sub-list {
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
    }
  }

{% endstyle %}

{% schema %}
{
  "name": "Luxury Brand Nav",
  "tag": "div",
  "class": "shopify-section--luxury-brand-nav",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "MAISON"
    },
    {
      "type": "url",
      "id": "brand_link",
      "label": "Brand link"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Brand logo (overrides name)"
    },
    {
      "type": "range",
      "id": "brand_logo_height",
      "label": "Logo height",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "select",
      "id": "brand_font",
      "label": "Brand name font",
      "options": [
        { "value": "var(--font-heading--family)", "label": "Heading" },
        { "value": "var(--font-body--family)", "label": "Body" },
        { "value": "var(--font-accent--family)", "label": "Accent" },
        { "value": "Georgia, serif", "label": "Georgia" }
      ],
      "default": "var(--font-heading--family)"
    },
    {
      "type": "range",
      "id": "brand_font_size",
      "label": "Brand name size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "brand_font_weight",
      "label": "Brand name weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "300"
    },
    {
      "type": "header",
      "content": "Tab labels"
    },
    {
      "type": "select",
      "id": "label_font",
      "label": "Font",
      "options": [
        { "value": "var(--font-heading--family)", "label": "Heading" },
        { "value": "var(--font-body--family)", "label": "Body" },
        { "value": "var(--font-accent--family)", "label": "Accent" },
        { "value": "Georgia, serif", "label": "Georgia" }
