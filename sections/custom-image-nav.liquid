    {
      "type": "range",
      "id": "label_font_size",
      "label": "Font size",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "select",
      "id": "label_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "300"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing (1/1000 em)",
      "min": 0,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 200
