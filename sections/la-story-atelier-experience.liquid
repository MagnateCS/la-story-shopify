<section class="la-story-atelier">
  <div class="la-story-container">
    <div class="la-story-atelier__grid">
      <div class="la-story-atelier__content">
        <h2>{{ section.settings.heading }}</h2>

        <div class="la-story-atelier__text">
          {{ section.settings.text }}
        </div>

        <div class="la-story-atelier__list">
          {% for block in section.blocks %}
            <div {{ block.shopify_attributes }}>
              <strong>{{ block.settings.number }}</strong>
              <div>
                <h3>{{ block.settings.heading }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="la-story-atelier__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              class: 'la-story-atelier__image',
              loading: 'lazy',
              alt: section.settings.heading
          }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .la-story-atelier {
    background: #f8f3ec;
    color: #211b17;
    padding: 92px 0;
  }

  .la-story-container {
    max-width: 1480px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  .la-story-atelier__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid rgba(33, 27, 23, 0.16);
    background: #fffdf8;
  }

  .la-story-atelier__content {
    padding: clamp(40px, 5.5vw, 78px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .la-story-atelier h2 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(36px, 4.2vw, 58px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  .la-story-atelier__text {
    margin-top: 22px;
    color: rgba(33, 27, 23, 0.66);
    font-size: 15px;
    line-height: 1.85;
  }

  .la-story-atelier__media {
    min-height: 620px;
    border-left: 1px solid rgba(33, 27, 23, 0.16);
    background: #d9c7b4;
  }

  .la-story-atelier__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .la-story-atelier__list {
    margin-top: 30px;
    border-top: 1px solid rgba(33, 27, 23, 0.16);
  }

  .la-story-atelier__list div {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px;
    padding: 18px 0;
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  .la-story-atelier__list strong {
    color: #b99a72;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 24px;
    line-height: 1;
    font-weight: 400;
  }

  .la-story-atelier__list h3 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 24px;
    line-height: 1.05;
    font-weight: 400;
  }

  .la-story-atelier__list p {
    margin: 8px 0 0;
    color: rgba(33, 27, 23, 0.66);
    font-size: 14px;
    line-height: 1.7;
  }

  @media screen and (max-width: 1120px) {
    .la-story-atelier__grid {
      grid-template-columns: 1fr;
    }

    .la-story-atelier__media {
      border-left: 0;
      border-top: 1px solid rgba(33, 27, 23, 0.16);
    }
  }

  @media screen and (max-width: 760px) {
    .la-story-atelier {
      padding: 68px 0;
    }

    .la-story-container {
      padding-left: 18px;
      padding-right: 18px;
    }

    .la-story-atelier__content {
      padding: 34px 24px;
    }

    .la-story-atelier__media {
      min-height: 420px;
    }
  }
</style>

{% schema %}
{
  "name": "Atelier Experience",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury is in the fit, not the noise."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The design direction should feel quiet, precise, and elevated: less like a mass ecommerce marketplace and more like a bridal atelier that happens to sell online."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Consultation"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Start with the garment, the event, the timeline, and the desired final shape."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LA Story Atelier Experience",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "heading": "Consultation",
            "text": "Start with the garment, the event, the timeline, and the desired final shape."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "heading": "Fitting",
            "text": "Adjustments are planned around comfort, proportion, movement, and garment construction."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "heading": "Final Refinement",
            "text": "Steam, polish, and finish the garment so it is ready for the moment it was made for."
          }
        }
      ]
    }
  ]
}
{% endschema %}