{% liquid
  assign section_id = 'la-story-location-contact-cards-' | append: section.id
%}

<section id="{{ section_id }}" class="la-story-location-contact">
  <div class="la-story-location-contact__inner">
    <div class="la-story-location-contact__grid">
      <figure class="la-story-location-contact__map">
        {% if section.settings.map_image != blank %}
          {{
            section.settings.map_image
            | image_url: width: 2200
            | image_tag:
              loading: 'lazy',
              alt: section.settings.map_alt,
              class: 'la-story-location-contact__map-image'
          }}
        {% else %}
          <div class="la-story-location-contact__map-placeholder">
            {{ 'image' | placeholder_svg_tag: 'la-story-location-contact__placeholder-svg' }}
          </div>
        {% endif %}

        <figcaption class="la-story-location-contact__map-caption">
          {% if section.settings.map_kicker != blank %}
            <p class="la-story-location-contact__caption-kicker">
              {{ section.settings.map_kicker }}
            </p>
          {% endif %}

          {% if section.settings.map_title != blank %}
            <p class="la-story-location-contact__caption-title">
              {{ section.settings.map_title }}
            </p>
          {% endif %}

          {% if section.settings.map_address != blank %}
            <div class="la-story-location-contact__caption-address">
              {{ section.settings.map_address | newline_to_br }}
            </div>
          {% endif %}
        </figcaption>
      </figure>

      <div class="la-story-location-contact__cards">
        {% for block in section.blocks %}
          <article class="la-story-location-contact__card" {{ block.shopify_attributes }}>
            {% if block.settings.kicker != blank %}
              <p class="la-story-location-contact__card-kicker">
                {{ block.settings.kicker }}
              </p>
            {% endif %}

            {% if block.settings.title != blank %}
              <h2 class="la-story-location-contact__card-title">
                {{ block.settings.title }}
              </h2>
            {% endif %}

            <div class="la-story-location-contact__entries">
              {% if block.settings.entry_1_label != blank %}
                <div>
                  {% if block.settings.entry_1_link != blank %}
                    <a href="{{ block.settings.entry_1_link }}" class="la-story-location-contact__entry-link">
                      {{ block.settings.entry_1_label }}
                    </a>
                  {% else %}
                    <p>{{ block.settings.entry_1_label }}</p>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.entry_2_label != blank %}
                <div>
                  {% if block.settings.entry_2_link != blank %}
                    <a href="{{ block.settings.entry_2_link }}" class="la-story-location-contact__entry-link">
                      {{ block.settings.entry_2_label }}
                    </a>
                  {% else %}
                    <p>{{ block.settings.entry_2_label }}</p>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.entry_3_label != blank %}
                <div>
                  {% if block.settings.entry_3_link != blank %}
                    <a href="{{ block.settings.entry_3_link }}" class="la-story-location-contact__entry-link">
                      {{ block.settings.entry_3_label }}
                    </a>
                  {% else %}
                    <p>{{ block.settings.entry_3_label }}</p>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.entry_4_label != blank %}
                <div>
                  {% if block.settings.entry_4_link != blank %}
                    <a href="{{ block.settings.entry_4_link }}" class="la-story-location-contact__entry-link">
                      {{ block.settings.entry_4_label }}
                    </a>
                  {% else %}
                    <p>{{ block.settings.entry_4_label }}</p>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            {% if block.settings.button_1_label != blank or block.settings.button_2_label != blank %}
              <div class="la-story-location-contact__buttons">
                {% if block.settings.button_1_label != blank %}
                  <a
                    href="{{ block.settings.button_1_link | default: '#' }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="la-story-location-contact__button"
                  >
                    {{ block.settings.button_1_label }}
                  </a>
                {% endif %}

                {% if block.settings.button_2_label != blank %}
                  <a
                    href="{{ block.settings.button_2_link | default: '#' }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="la-story-location-contact__button"
                  >
                    {{ block.settings.button_2_label }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    --la-story-black: #0f0f0f;
    --la-story-paper: #f6f0e6;
    --la-story-ink: #171717;
    --la-story-muted: rgba(23, 23, 23, 0.68);
    --la-story-gold: #c7a35b;
    --la-story-white-border: rgba(255, 255, 255, 0.1);
    --la-story-dark-border: rgba(23, 23, 23, 0.12);
    --la-story-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);

    background: var(--la-story-black);
    color: var(--la-story-ink);
    padding: 36px 24px 56px;
  }

  #{{ section_id }} .la-story-location-contact__inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  #{{ section_id }} .la-story-location-contact__grid {
    display: grid;
    grid-template-columns: 1.5fr 0.9fr;
    gap: 24px;
    align-items: stretch;
  }

  #{{ section_id }} .la-story-location-contact__map {
    position: relative;
    min-height: 520px;
    margin: 0;
    overflow: hidden;
    background: var(--la-story-paper);
    border: 1px solid var(--la-story-white-border);
    box-shadow: var(--la-story-shadow);
    animation: laStoryLocationFadeUp-{{ section.id }} 800ms ease both;
  }

  #{{ section_id }} .la-story-location-contact__map-image,
  #{{ section_id }} .la-story-location-contact__map-placeholder,
  #{{ section_id }} .la-story-location-contact__placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #{{ section_id }} .la-story-location-contact__map-image {
    object-fit: cover;
  }

  #{{ section_id }} .la-story-location-contact__map-placeholder {
    background: #242424;
  }

  #{{ section_id }} .la-story-location-contact__placeholder-svg {
    opacity: 0.35;
  }

  #{{ section_id }} .la-story-location-contact__map-caption {
    position: absolute;
    left: 28px;
    bottom: 28px;
    z-index: 2;
    max-width: 340px;
    background: rgba(0, 0, 0, 0.82);
    border: 1px solid var(--la-story-white-border);
    padding: 22px;
    backdrop-filter: blur(10px);
  }

  #{{ section_id }} .la-story-location-contact__caption-kicker {
    margin: 0;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 11px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.62);
  }

  #{{ section_id }} .la-story-location-contact__caption-title {
    margin: 10px 0 0;
    font-family: Georgia, serif;
    font-size: 30px;
    line-height: 1;
    color: #ffffff;
  }

  #{{ section_id }} .la-story-location-contact__caption-address {
    margin-top: 10px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
  }

  #{{ section_id }} .la-story-location-contact__cards {
    display: grid;
    gap: 24px;
  }

  #{{ section_id }} .la-story-location-contact__card {
    background: var(--la-story-paper);
    border: 1px solid var(--la-story-dark-border);
    box-shadow: var(--la-story-shadow);
    padding: 32px;
    animation: laStoryLocationFadeUp-{{ section.id }} 800ms ease both;
  }

  #{{ section_id }} .la-story-location-contact__card-kicker {
    margin: 0;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 12px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: var(--la-story-muted);
  }

  #{{ section_id }} .la-story-location-contact__card-title {
    margin: 16px 0 0;
    font-family: Georgia, serif;
    font-size: 34px;
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--la-story-ink);
  }

  #{{ section_id }} .la-story-location-contact__entries {
    margin-top: 22px;
    display: grid;
    gap: 10px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: var(--la-story-muted);
  }

  #{{ section_id }} .la-story-location-contact__entries p {
    margin: 0;
  }

  #{{ section_id }} .la-story-location-contact__entry-link {
    color: var(--la-story-muted);
    text-decoration: none;
    transition: color 180ms ease;
  }

  #{{ section_id }} .la-story-location-contact__entry-link:hover {
    color: var(--la-story-gold);
  }

  #{{ section_id }} .la-story-location-contact__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  #{{ section_id }} .la-story-location-contact__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    border: 1px solid rgba(23, 23, 23, 0.18);
    border-radius: 999px;
    padding: 11px 18px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 11px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--la-story-ink);
    text-decoration: none;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  #{{ section_id }} .la-story-location-contact__button:hover {
    background: var(--la-story-gold);
    border-color: var(--la-story-gold);
    color: #000000;
    transform: translateY(-2px);
  }

  @keyframes laStoryLocationFadeUp-{{ section.id }} {
    from {
      opacity: 0;
      transform: translateY(28px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 989px) {
    #{{ section_id }} {
      padding: 28px 16px 48px;
    }

    #{{ section_id }} .la-story-location-contact__grid {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .la-story-location-contact__map {
      min-height: 420px;
    }
  }

  @media screen and (max-width: 640px) {
    #{{ section_id }} .la-story-location-contact__map {
      min-height: 360px;
    }

    #{{ section_id }} .la-story-location-contact__map-caption {
      left: 16px;
      right: 16px;
      bottom: 16px;
      max-width: none;
      padding: 18px;
    }

    #{{ section_id }} .la-story-location-contact__card {
      padding: 26px 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .la-story-location-contact__map,
    #{{ section_id }} .la-story-location-contact__card,
    #{{ section_id }} .la-story-location-contact__button {
      animation: none;
      transition: none;
    }
  }
</style>

