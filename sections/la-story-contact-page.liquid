      "default": "Browse Services"
    },
    {
      "type": "url",
      "id": "bottom_button_link",
      "label": "Bottom button link"
    }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info card",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Alterations"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Ask about tailoring, hems, reshaping, zippers, and garment adjustments."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LA Story Contact Page",
      "blocks": [
        {
          "type": "info_card",
          "settings": {
            "number": "01",
            "heading": "Alterations",
            "text": "Ask about tailoring, hems, reshaping, zippers, and garment adjustments."
