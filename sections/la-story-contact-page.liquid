        },
        {
          "type": "info_card",
          "settings": {
            "number": "02",
            "heading": "Fittings",
            "text": "Schedule a private fitting for bridal, formalwear, or event garments."
          }
        },
        {
          "type": "info_card",
          "settings": {
            "number": "03",
            "heading": "Store Waitlist",
            "text": "Join the waitlist for the upcoming LA STORY bridal store."
          }
        }
      ]
    }
  ]
}
{% endschema %}