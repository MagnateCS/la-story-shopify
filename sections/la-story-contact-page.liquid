<section id="la-story-contact-{{ section.id }}" class="la-story-contact-page">
  <div class="la-story-contact-page__container">

    <header class="la-story-contact-page__hero">
      <div>
        <h1>{{ section.settings.heading }}</h1>

        {% if section.settings.text != blank %}
          <p>{{ section.settings.text }}</p>
        {% endif %}
      </div>

      <div class="la-story-contact-page__hero-note">
        {% if section.settings.note != blank %}
          <p>{{ section.settings.note }}</p>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </header>

    <div class="la-story-contact-page__panel">

      <div class="la-story-contact-page__info">
        <h2>{{ section.settings.form_heading }}</h2>

        {% if section.settings.form_text != blank %}
          <p>{{ section.settings.form_text }}</p>
        {% endif %}

        <div class="la-story-contact-page__details">
          {% if section.settings.phone != blank %}
            <div>
              <span>Phone</span>
              <p>{{ section.settings.phone }}</p>
            </div>
          {% endif %}

          {% if section.settings.email != blank %}
            <div>
              <span>Email</span>
              <p>{{ section.settings.email }}</p>
            </div>
          {% endif %}

          {% if section.settings.location != blank %}
            <div>
              <span>Location</span>
              <p>{{ section.settings.location }}</p>
            </div>
          {% endif %}

          {% if section.settings.hours != blank %}
            <div>
              <span>Hours</span>
              <p>{{ section.settings.hours }}</p>
            </div>
          {% endif %}
        </div>
      </div>

      {% form 'contact', class: 'la-story-contact-page__form' %}
        {% if form.posted_successfully? %}
          <p class="la-story-contact-page__success">
            {{ section.settings.success_message }}
          </p>
        {% endif %}

        {% if form.errors %}
          <div class="la-story-contact-page__error">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="la-story-contact-page__form-grid">
          <div class="la-story-contact-page__field">
            <label for="ContactFormName-{{ section.id }}">Name</label>
            <input
              id="ContactFormName-{{ section.id }}"
              type="text"
              name="contact[name]"
              autocomplete="name"
              placeholder="Your name"
              required
            >
          </div>

          <div class="la-story-contact-page__field">
            <label for="ContactFormEmail-{{ section.id }}">Email</label>
            <input
              id="ContactFormEmail-{{ section.id }}"
              type="email"
              name="contact[email]"
              autocomplete="email"
              placeholder="Email address"
              required
            >
          </div>

          <div class="la-story-contact-page__field">
            <label for="ContactFormPhone-{{ section.id }}">Phone</label>
            <input
              id="ContactFormPhone-{{ section.id }}"
              type="tel"
              name="contact[phone]"
              autocomplete="tel"
              placeholder="Phone number"
            >
          </div>

          <div class="la-story-contact-page__field">
            <label for="ContactFormInterest-{{ section.id }}">Inquiry Type</label>
            <select
              id="ContactFormInterest-{{ section.id }}"
              name="contact[inquiry_type]"
            >
              <option value="Alterations">Alterations</option>
              <option value="Bridal fitting">Bridal fitting</option>
              <option value="Formal dress alterations">Formal dress alterations</option>
              <option value="Store waitlist">Store waitlist</option>
              <option value="General question">General question</option>
            </select>
          </div>

          <div class="la-story-contact-page__field">
            <label for="ContactFormEventDate-{{ section.id }}">Event Date</label>
            <input
              id="ContactFormEventDate-{{ section.id }}"
              type="text"
              name="contact[event_date]"
              placeholder="Wedding or event date"
            >
          </div>

          <div class="la-story-contact-page__field">
            <label for="ContactFormGarment-{{ section.id }}">Garment Type</label>
            <input
              id="ContactFormGarment-{{ section.id }}"
              type="text"
              name="contact[garment_type]"
              placeholder="Gown, dress, pants, blouse, etc."
            >
          </div>

          <div class="la-story-contact-page__field la-story-contact-page__field--full">
            <label for="ContactFormMessage-{{ section.id }}">Message</label>
            <textarea
              id="ContactFormMessage-{{ section.id }}"
              name="contact[body]"
              placeholder="Tell us about your garment, timeline, and what you need adjusted."
              required
            ></textarea>
          </div>
        </div>

        <button type="submit" class="la-story-contact-page__submit">
          {{ section.settings.submit_label }}
        </button>
      {% endform %}

    </div>

    <div class="la-story-contact-page__cards">
      {% for block in section.blocks %}
        <article class="la-story-contact-page__card" {{ block.shopify_attributes }}>
          <span>{{ block.settings.number }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>

    <div class="la-story-contact-page__bottom">
      <div>
        <h2>{{ section.settings.bottom_heading }}</h2>
        <p>{{ section.settings.bottom_text }}</p>
      </div>

      {% if section.settings.bottom_button_label != blank %}
        <a href="{{ section.settings.bottom_button_link }}">
          {{ section.settings.bottom_button_label }}
        </a>
      {% endif %}
    </div>

  </div>
</section>

<style>
  #la-story-contact-{{ section.id }} {
    background: #f8f3ec;
    color: #211b17;
    padding: 28px 0 92px;
  }

  #la-story-contact-{{ section.id }} *,
  #la-story-contact-{{ section.id }} *::before,
  #la-story-contact-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__container {
    max-width: 1480px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 64px;
    align-items: end;
    padding: 72px 0 56px;
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__hero h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(42px, 5vw, 72px);
    line-height: 0.98;
    font-weight: 400;
    letter-spacing: -0.045em;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__hero p {
    margin: 24px 0 0;
    max-width: 680px;
    color: rgba(33, 27, 23, 0.66);
    font-size: 15px;
    line-height: 1.85;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__hero-note {
    border-left: 1px solid rgba(33, 27, 23, 0.16);
    padding-left: 36px;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__hero-note p {
    margin-top: 0;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__hero-note a,
  #la-story-contact-{{ section.id }} .la-story-contact-page__bottom a,
  #la-story-contact-{{ section.id }} .la-story-contact-page__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 26px;
    border: 1px solid #211b17;
    background: #211b17;
    color: #fff;
    padding: 0 28px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__hero-note a:hover,
  #la-story-contact-{{ section.id }} .la-story-contact-page__bottom a:hover,
  #la-story-contact-{{ section.id }} .la-story-contact-page__submit:hover {
    background: transparent;
    color: #211b17;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__panel {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    margin-top: 64px;
    background: #11100f;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__info {
    padding: clamp(40px, 5.5vw, 78px);
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__info h2,
  #la-story-contact-{{ section.id }} .la-story-contact-page__bottom h2 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__info > p {
    margin: 22px 0 0;
    max-width: 560px;
    color: rgba(255, 255, 255, 0.64);
    font-size: 15px;
    line-height: 1.85;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__details {
    display: grid;
    gap: 22px;
    margin-top: 42px;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding-top: 30px;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__details div {
    display: grid;
    gap: 6px;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__details span {
    color: rgba(255, 255, 255, 0.42);
    font-size: 10px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__details p {
    margin: 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 14px;
    line-height: 1.7;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__form {
    border-left: 1px solid rgba(255, 255, 255, 0.18);
    padding: clamp(40px, 5.5vw, 78px);
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 22px;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__field {
    display: grid;
    gap: 8px;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__field--full {
    grid-column: 1 / -1;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__field label {
    color: rgba(255, 255, 255, 0.48);
    font-size: 10px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__field input,
  #la-story-contact-{{ section.id }} .la-story-contact-page__field select,
  #la-story-contact-{{ section.id }} .la-story-contact-page__field textarea {
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.34);
    background: transparent;
    color: #fff;
    padding: 12px 0 14px;
    outline: none;
    font-size: 14px;
    line-height: 1.5;
    border-radius: 0;
    appearance: none;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__field select {
    cursor: pointer;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__field input::placeholder,
  #la-story-contact-{{ section.id }} .la-story-contact-page__field textarea::placeholder {
    color: rgba(255, 255, 255, 0.42);
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__field textarea {
    min-height: 130px;
    resize: vertical;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__success {
    margin: 0 0 24px;
    color: #d9d0bb;
    font-size: 14px;
    line-height: 1.6;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__error {
    margin: 0 0 24px;
    color: #f0b4a8;
    font-size: 14px;
    line-height: 1.6;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__submit {
    background: #fff;
    color: #211b17;
    border-color: #fff;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__submit:hover {
    background: transparent;
    color: #fff;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 64px;
    border-left: 1px solid rgba(33, 27, 23, 0.16);
    border-top: 1px solid rgba(33, 27, 23, 0.16);
    background: #fffdf8;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__card {
    padding: 30px;
    border-right: 1px solid rgba(33, 27, 23, 0.16);
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__card span {
    display: block;
    margin-bottom: 18px;
    color: #b99a72;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 25px;
    line-height: 1;
    font-weight: 400;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__card h3 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 27px;
    line-height: 1.05;
    font-weight: 400;
    letter-spacing: -0.03em;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__card p {
    margin: 12px 0 0;
    color: rgba(33, 27, 23, 0.66);
    font-size: 14px;
    line-height: 1.75;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__bottom {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 34px;
    align-items: center;
    margin-top: 64px;
    padding: 42px;
    border: 1px solid rgba(33, 27, 23, 0.16);
    background: #fffdf8;
  }

  #la-story-contact-{{ section.id }} .la-story-contact-page__bottom p {
    margin: 16px 0 0;
    max-width: 760px;
    color: rgba(33, 27, 23, 0.66);
    font-size: 15px;
    line-height: 1.85;
  }

  @media screen and (max-width: 1120px) {
    #la-story-contact-{{ section.id }} .la-story-contact-page__hero,
    #la-story-contact-{{ section.id }} .la-story-contact-page__panel,
    #la-story-contact-{{ section.id }} .la-story-contact-page__bottom {
      grid-template-columns: 1fr;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__hero-note {
      border-left: 0;
      padding-left: 0;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__form {
      border-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.18);
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__cards {
      grid-template-columns: 1fr;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__bottom a {
      width: fit-content;
    }
  }

  @media screen and (max-width: 760px) {
    #la-story-contact-{{ section.id }} {
      padding: 18px 0 68px;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__container {
      padding-left: 18px;
      padding-right: 18px;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__hero {
      padding: 54px 0 38px;
      gap: 28px;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__panel {
      margin-top: 46px;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__info,
    #la-story-contact-{{ section.id }} .la-story-contact-page__form {
      padding: 34px 24px;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__form-grid {
      grid-template-columns: 1fr;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__cards {
      margin-top: 46px;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__bottom {
      margin-top: 46px;
      padding: 28px 22px;
    }

    #la-story-contact-{{ section.id }} .la-story-contact-page__hero-note a,
    #la-story-contact-{{ section.id }} .la-story-contact-page__bottom a,
    #la-story-contact-{{ section.id }} .la-story-contact-page__submit {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "LA Story Contact Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact the atelier."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Intro text",
      "default": "Reach out to schedule a fitting, ask about alterations, or join the waitlist for the upcoming LA STORY bridal store."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Side note",
      "default": "For the most accurate alteration estimate, please include your garment type, event date, and a brief description of the fit or tailoring needed."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Hero button label",
      "default": "View Services"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Hero button link"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Tell us what you need."
    },
    {
      "type": "textarea",
      "id": "form_text",
      "label": "Form text",
      "default": "Share a few details about your garment, timeline, and the service you are interested in. We will follow up with next steps."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "(000) 000-0000"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@lastorybridal.com"
    },
    {
      "type": "textarea",
      "id": "location",
      "label": "Location",
      "default": "Los Angeles, California"
    },
    {
      "type": "textarea",
      "id": "hours",
