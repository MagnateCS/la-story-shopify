<section id="la-story-store-coming-soon-{{ section.id }}" class="la-story-store-coming-soon">
  <div class="la-story-store-coming-soon__container">
    <div class="la-story-store-coming-soon__hero">
      <div class="la-story-store-coming-soon__media">
        {% if section.settings.hero_image != blank %}
          {{
            section.settings.hero_image
            | image_url: width: 1600
            | image_tag:
              class: 'la-story-store-coming-soon__image',
              loading: 'eager',
              alt: section.settings.heading
          }}
        {% endif %}
      </div>

      <div class="la-story-store-coming-soon__content">
        {% if section.settings.heading != blank %}
          <h1>{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="la-story-store-coming-soon__text">
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% form 'customer', class: 'la-story-store-coming-soon__form' %}
          <input type="hidden" name="contact[tags]" value="store-waitlist, bridal-preview">

          {% if form.posted_successfully? %}
            <p class="la-story-store-coming-soon__success">
              {{ section.settings.success_message }}
            </p>
          {% endif %}

          {% if form.errors %}
            <div class="la-story-store-coming-soon__error">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="la-story-store-coming-soon__form-row">
            <input
              type="email"
              name="contact[email]"
              placeholder="{{ section.settings.email_placeholder }}"
              required
            >

            <button type="submit">
              {{ section.settings.button_label }}
            </button>
          </div>
        {% endform %}

        <div class="la-story-store-coming-soon__actions">
          {% if section.settings.services_label != blank %}
            <a href="{{ section.settings.services_link }}" class="la-story-store-coming-soon__link">
              {{ section.settings.services_label }}
            </a>
          {% endif %}

          {% if section.settings.contact_label != blank %}
            <a href="{{ section.settings.contact_link }}" class="la-story-store-coming-soon__link">
              {{ section.settings.contact_label }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="la-story-store-coming-soon__intro">
      <div>
        <h2>{{ section.settings.preview_heading }}</h2>
      </div>

      <p>
        {{ section.settings.preview_text }}
      </p>
    </div>

    <div class="la-story-store-coming-soon__grid">
      {% for block in section.blocks %}
        <article class="la-story-store-coming-soon__card" {{ block.shopify_attributes }}>
          <div class="la-story-store-coming-soon__card-media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  class: 'la-story-store-coming-soon__card-image',
                  loading: 'lazy',
                  alt: block.settings.title
              }}
            {% endif %}
          </div>

          <div class="la-story-store-coming-soon__card-content">
            <span>{{ block.settings.label }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </article>
      {% endfor %}
    </div>

    <div class="la-story-store-coming-soon__note">
      <div>
        <h2>{{ section.settings.bottom_heading }}</h2>
        <p>{{ section.settings.bottom_text }}</p>
      </div>

      {% if section.settings.bottom_button_label != blank %}
        <a href="{{ section.settings.bottom_button_link }}">
          {{ section.settings.bottom_button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #la-story-store-coming-soon-{{ section.id }} {
    background: #f8f3ec;
    color: #211b17;
    padding: 28px 0 92px;
  }

  #la-story-store-coming-soon-{{ section.id }} *,
  #la-story-store-coming-soon-{{ section.id }} *::before,
  #la-story-store-coming-soon-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__container {
    max-width: 1480px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 680px;
    background: #fffdf8;
    border: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__media {
    position: relative;
    min-height: 680px;
    background: #d9c7b4;
    overflow: hidden;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.28), transparent 52%),
      linear-gradient(0deg, rgba(0, 0, 0, 0.22), transparent 60%);
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__image,
  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(42px, 6vw, 88px);
    border-left: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-store-coming-soon-{{ section.id }} h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(42px, 5vw, 72px);
    line-height: 0.98;
    font-weight: 400;
    letter-spacing: -0.045em;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__text {
    max-width: 560px;
    margin-top: 24px;
    color: rgba(33, 27, 23, 0.66);
    font-size: 15px;
    line-height: 1.85;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form {
    margin-top: 34px;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    max-width: 560px;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form input {
    width: 100%;
    min-height: 50px;
    border: 0;
    border-bottom: 1px solid rgba(33, 27, 23, 0.34);
    background: transparent;
    color: #211b17;
    outline: none;
    font-size: 14px;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form input::placeholder {
    color: rgba(33, 27, 23, 0.42);
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form button,
  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note a {
    min-height: 50px;
    border: 1px solid #211b17;
    background: #211b17;
    color: #fff;
    padding: 0 28px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form button:hover,
  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note a:hover {
    background: transparent;
    color: #211b17;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__success {
    margin: 0 0 18px;
    color: #5e6d4c;
    font-size: 14px;
    line-height: 1.6;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__error {
    margin: 0 0 18px;
    color: #8f2f24;
    font-size: 14px;
    line-height: 1.6;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin-top: 28px;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__link {
    border-bottom: 1px solid #211b17;
    padding-bottom: 4px;
    color: #211b17;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__intro {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 60px;
    align-items: end;
    padding: 92px 0 50px;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__intro h2,
  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note h2 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__intro p,
  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note p {
    margin: 0;
    color: rgba(33, 27, 23, 0.66);
    font-size: 15px;
    line-height: 1.85;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(33, 27, 23, 0.16);
    border-left: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__card {
    background: #fffdf8;
    border-right: 1px solid rgba(33, 27, 23, 0.16);
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__card-media {
    aspect-ratio: 4 / 5;
    background: #d9c7b4;
    overflow: hidden;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__card-content {
    padding: 24px;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__card-content span {
    display: block;
    margin-bottom: 12px;
    color: #877768;
    font-size: 10px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__card-content h3 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 26px;
    line-height: 1.05;
    font-weight: 400;
    letter-spacing: -0.03em;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__card-content p {
    margin: 12px 0 0;
    color: rgba(33, 27, 23, 0.66);
    font-size: 14px;
    line-height: 1.75;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 34px;
    align-items: center;
    margin-top: 64px;
    padding: 42px;
    border: 1px solid rgba(33, 27, 23, 0.16);
    background: #fffdf8;
  }

  #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note p {
    margin-top: 16px;
    max-width: 760px;
  }

  @media screen and (max-width: 1120px) {
    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__hero,
    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__intro,
    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note {
      grid-template-columns: 1fr;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__content {
      border-left: 0;
      border-top: 1px solid rgba(33, 27, 23, 0.16);
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__media {
      min-height: 560px;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note a {
      width: fit-content;
    }
  }

  @media screen and (max-width: 760px) {
    #la-story-store-coming-soon-{{ section.id }} {
      padding: 18px 0 68px;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__container {
      padding-left: 18px;
      padding-right: 18px;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__media {
      min-height: 420px;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__content {
      padding: 34px 24px;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form-row,
    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__grid {
      grid-template-columns: 1fr;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__form button,
    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note a {
      width: 100%;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__intro {
      padding: 68px 0 38px;
      gap: 24px;
    }

    #la-story-store-coming-soon-{{ section.id }} .la-story-store-coming-soon__note {
      margin-top: 44px;
      padding: 28px 22px;
    }
  }
</style>

