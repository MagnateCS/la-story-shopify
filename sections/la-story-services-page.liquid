<style>
  #la-story-services-{{ section.id }} {
    background: #f8f3ec;
    color: #211b17;
    padding: 28px 0 92px;
  }

  #la-story-services-{{ section.id }} *,
  #la-story-services-{{ section.id }} *::before,
  #la-story-services-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__container {
    max-width: 1480px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 64px;
    align-items: end;
    padding: 72px 0 56px;
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-services-{{ section.id }} .la-story-services-page__hero h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(42px, 5vw, 72px);
    line-height: 0.98;
    font-weight: 400;
    letter-spacing: -0.045em;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__hero p {
    margin: 24px 0 0;
    max-width: 680px;
    color: rgba(33, 27, 23, 0.66);
    font-size: 15px;
    line-height: 1.85;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__hero-note {
    border-left: 1px solid rgba(33, 27, 23, 0.16);
    padding-left: 36px;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__hero-note p {
    margin-top: 0;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__hero-note a,
  #la-story-services-{{ section.id }} .la-story-services-page__footer a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 26px;
    border: 1px solid #211b17;
    background: #211b17;
    color: #fff;
    padding: 0 28px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__hero-note a:hover,
  #la-story-services-{{ section.id }} .la-story-services-page__footer a:hover {
    background: transparent;
    color: #211b17;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__nav {
    position: sticky;
    top: var(--header-height, 0px);
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin: 0 0 56px;
    background: #f8f3ec;
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-services-{{ section.id }} .la-story-services-page__nav a {
    display: inline-flex;
    align-items: center;
    min-height: 54px;
    padding: 0 22px;
    border-right: 1px solid rgba(33, 27, 23, 0.16);
    color: rgba(33, 27, 23, 0.72);
    font-size: 11px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__nav a:first-child {
    border-left: 1px solid rgba(33, 27, 23, 0.16);
  }

  #la-story-services-{{ section.id }} .la-story-services-page__nav a:hover {
    color: #211b17;
    background: #fffdf8;
  }

  #la-story-services-{{ section.id }} .la-story-services-page__groups {
    display: grid;
    gap: 76px;
  }

  #la-story-services-{{ section.id }} .la-story-service-group {
    display: grid;
    grid-template-columns: 0.36fr 0.64fr;
    gap: 54px;
    scroll-margin-top: 120px;
  }

  #la-story-services-{{ section.id }} .la-story-service-group__header {
    position: sticky;
    top: 96px;
    align-self: start;
  }

  #la-story-services-{{ section.id }} .la-story-service-group__header span {
    display: block;
    margin-bottom: 18px;
    color: #b99a72;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 28px;
    line-height: 1;
    font-weight: 400;
  }

  #la-story-services-{{ section.id }} .la-story-service-group__header h2 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(32px, 3.5vw, 52px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  #la-story-services-{{ section.id }} .la-story-service-group__header p {
    margin: 18px 0 0;
    color: rgba(33, 27, 23, 0.66);
    font-size: 14px;
    line-height: 1.8;
