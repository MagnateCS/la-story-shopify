<section id="la-story-services-{{ section.id }}" class="la-story-services-page">
  <div class="la-story-services-page__container">

    <header class="la-story-services-page__hero">
      <div>
        <h1>{{ section.settings.heading }}</h1>

        {% if section.settings.text != blank %}
          <p>{{ section.settings.text }}</p>
        {% endif %}
      </div>

      <div class="la-story-services-page__hero-note">
        <p>{{ section.settings.note }}</p>

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </header>

    <nav class="la-story-services-page__nav" aria-label="Service categories">
      <a href="#womens-clothing-alterations">Women’s Clothing</a>
