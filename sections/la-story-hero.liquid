<section class="la-story-hero">
  <div class="la-story-container">
    <div class="la-story-hero__grid">
      <div class="la-story-hero__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1800
            | image_tag:
              class: 'la-story-hero__image',
              loading: 'eager',
              alt: section.settings.heading
          }}
        {% endif %}
      </div>

      <div class="la-story-hero__content">
        <h1>{{ section.settings.heading }}</h1>

        <div class="la-story-hero__text">
          {{ section.settings.text }}
        </div>

        <div class="la-story-button-row">
          {% if section.settings.primary_label != blank %}
            <a href="{{ section.settings.primary_link }}" class="la-story-button la-story-button--dark">
              {{ section.settings.primary_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_label != blank %}
            <a href="{{ section.settings.secondary_link }}" class="la-story-button la-story-button--outline">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>

        <div class="la-story-hero__meta">
          {% for block in section.blocks %}
            <div {{ block.shopify_attributes }}>
              <strong>{{ block.settings.number }}</strong>
              <span>{{ block.settings.text }}</span>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .la-story-hero {
    background: #f8f3ec;
    padding: 28px 0 88px;
    color: #211b17;
  }

  .la-story-container {
    max-width: 1480px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  .la-story-hero__grid {
    display: grid;
    grid-template-columns: 1.04fr 0.96fr;
    min-height: 680px;
    border: 1px solid rgba(33, 27, 23, 0.16);
    background: #fffdf8;
  }

  .la-story-hero__media {
    position: relative;
    min-height: 680px;
    overflow: hidden;
    background: #d9c7b4;
  }

  .la-story-hero__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0.06)),
      linear-gradient(0deg, rgba(0, 0, 0, 0.22), transparent 58%);
  }

  .la-story-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .la-story-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 64px clamp(40px, 5.5vw, 88px);
    border-left: 1px solid rgba(33, 27, 23, 0.16);
  }

  .la-story-hero h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(42px, 5vw, 74px);
    line-height: 0.98;
    font-weight: 400;
    letter-spacing: -0.045em;
  }

  .la-story-hero__text {
    max-width: 560px;
    margin-top: 24px;
    color: rgba(33, 27, 23, 0.66);
    font-size: 16px;
    line-height: 1.85;
  }

  .la-story-button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .la-story-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 26px;
    border: 1px solid transparent;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }

  .la-story-button--dark {
    background: #211b17;
    color: #fff;
  }

  .la-story-button--dark:hover {
    background: transparent;
    border-color: #211b17;
    color: #211b17;
  }

  .la-story-button--outline {
    border-color: #211b17;
    color: #211b17;
  }

  .la-story-button--outline:hover {
    background: #211b17;
    color: #fff;
  }

  .la-story-hero__meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 46px;
    border-top: 1px solid rgba(33, 27, 23, 0.16);
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  .la-story-hero__meta div {
    padding: 16px 14px;
    border-right: 1px solid rgba(33, 27, 23, 0.16);
  }

  .la-story-hero__meta div:last-child {
    border-right: 0;
  }

  .la-story-hero__meta strong {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1;
    color: #b99a72;
  }

  .la-story-hero__meta span {
    display: block;
    margin-top: 8px;
    color: rgba(33, 27, 23, 0.66);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1.5;
  }

  @media screen and (max-width: 1120px) {
    .la-story-hero__grid {
      grid-template-columns: 1fr;
    }

    .la-story-hero__content {
      border-left: 0;
      border-top: 1px solid rgba(33, 27, 23, 0.16);
    }

    .la-story-hero__media {
      min-height: 580px;
    }
  }

  @media screen and (max-width: 760px) {
    .la-story-container {
      padding-left: 18px;
      padding-right: 18px;
    }

    .la-story-hero {
      padding-top: 18px;
      padding-bottom: 64px;
    }

    .la-story-hero__media {
      min-height: 460px;
    }

    .la-story-hero__content {
      padding: 34px 24px;
    }

    .la-story-hero__meta {
      grid-template-columns: 1fr;
    }

    .la-story-hero__meta div {
      border-right: 0;
      border-bottom: 1px solid rgba(33, 27, 23, 0.16);
    }

    .la-story-hero__meta div:last-child {
      border-bottom: 0;
    }

    .la-story-button-row {
      flex-direction: column;
    }

    .la-story-button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "LA Story Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tailored for the story you wear."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "LA STORY is a bridal atelier specializing in women’s alterations, formalwear, and bridal fittings, with a curated online bridal store coming soon."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Browse Services"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Join Store Waitlist"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "meta_item",
      "name": "Meta item",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Alterations available now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LA Story Hero",
      "blocks": [
        {
          "type": "meta_item",
          "settings": {
            "number": "01",
            "text": "Alterations available now"
          }
        },
        {
          "type": "meta_item",
          "settings": {
            "number": "02",
            "text": "Bridal store coming soon"
          }
        },
        {
          "type": "meta_item",
          "settings": {
            "number": "03",
            "text": "Private fitting appointments"
          }
        }
      ]
    }
  ]
}
{% endschema %}