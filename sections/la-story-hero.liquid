<section class="mx-auto grid max-w-[1500px] grid-cols-1 gap-5 px-5 py-6 lg:grid-cols-[1.2fr_0.8fr]">

  <!-- Large Hero -->
  <div class="relative min-h-[650px] overflow-hidden rounded-[2rem] bg-[#D8C4AF] shadow-[0_24px_70px_rgba(45,37,32,0.12)]">
    {% if section.settings.hero_image != blank %}
      {{
        section.settings.hero_image
        | image_url: width: 1800
        | image_tag:
          class: 'h-full w-full object-cover',
          loading: 'eager',
          alt: section.settings.hero_heading
      }}
    {% endif %}

    <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-black/15 to-transparent"></div>

    <div class="absolute bottom-0 left-0 max-w-2xl p-8 text-white md:p-14">
      <p class="mb-4 text-xs uppercase tracking-[0.3em] text-white/75">
        {{ section.settings.hero_eyebrow }}
      </p>

      <h1 class="font-serif text-5xl leading-[0.95] md:text-7xl">
        {{ section.settings.hero_heading }}
      </h1>

      <p class="mt-6 max-w-md text-base leading-8 text-white/80">
        {{ section.settings.hero_text }}
      </p>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        {% if section.settings.primary_label != blank %}
          <a href="{{ section.settings.primary_link }}" class="rounded-full bg-white px-8 py-4 text-center text-xs uppercase tracking-[0.22em] text-[#2D2520]">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank %}
          <a href="{{ section.settings.secondary_link }}" class="rounded-full border border-white/60 px-8 py-4 text-center text-xs uppercase tracking-[0.22em] text-white">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Right Promo Tiles -->
  <div class="grid grid-cols-1 gap-5">
    {% for block in section.blocks %}
      <div class="relative min-h-[315px] overflow-hidden rounded-[2rem] bg-[#E8CFC5] shadow-[0_24px_70px_rgba(45,37,32,0.12)]" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 1000
            | image_tag:
              class: 'h-full w-full object-cover',
              loading: 'lazy',
              alt: block.settings.heading
          }}
        {% endif %}

        <div class="absolute inset-0 bg-black/25"></div>

        <div class="absolute bottom-7 left-7 pr-7 text-white">
          <p class="text-xs uppercase tracking-[0.24em] text-white/75">
            {{ block.settings.eyebrow }}
          </p>

          <h2 class="mt-2 font-serif text-4xl">
            {{ block.settings.heading }}
          </h2>

          {% if block.settings.button_label != blank %}
            <a href="{{ block.settings.button_link }}" class="mt-4 inline-block border-b border-white pb-1 text-sm">
              {{ block.settings.button_label }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

</section>

{% schema %}
{
  "name": "LA Story Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow",
      "default": "Boutique Bridal Ecommerce"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Shop the gown. Book the perfect fit."
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Text",
      "default": "A bridal shopping experience built around dresses, appointments, alterations, and the final details that make the gown yours."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Dresses"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Book Fitting"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "promo_tile",
      "name": "Promo tile",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Coming Soon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "2026 Bridal Edit"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Join Waitlist"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LA Story Hero",
      "blocks": [
        {
          "type": "promo_tile"
        },
        {
          "type": "promo_tile",
          "settings": {
            "eyebrow": "Occasion Looks",
            "heading": "Little White Dresses",
            "button_label": "Shop Preview"
          }
        }
      ]
    }
  ]
}
{% endschema %}