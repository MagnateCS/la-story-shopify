{% if section.blocks.size > 1 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<aside
  class="announcement-bar la-story-announcement-bar spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-padding', settings: section.settings %};
    --border-bottom-width: {{ section.settings.divider_width }}px;
    --la-story-announcement-bg-start: {{ section.settings.background_start }};
    --la-story-announcement-bg-middle: {{ section.settings.background_middle }};
    --la-story-announcement-bg-end: {{ section.settings.background_end }};
    --la-story-announcement-text: {{ section.settings.text_color }};
    --la-story-announcement-accent: {{ section.settings.accent_color }};
    --la-story-announcement-border: {{ section.settings.border_color }};
    --la-story-announcement-arrow: {{ section.settings.arrow_color }};
    --la-story-announcement-arrow-hover: {{ section.settings.arrow_hover_color }};
    --la-story-announcement-glow-opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }};
  "
>
  {% liquid
    assign autoplay = false
    assign show_arrows = false

    if section.blocks.size > 1
      assign autoplay = true

      if section.settings.show_controls
        assign show_arrows = true
      endif
    endif
  %}

  <announcement-bar-component
    class="announcement-bar__slider la-story-announcement-bar__slider {% unless show_arrows %}la-story-announcement-bar__slider--no-controls{% endunless %}"
    {% if autoplay == true %}
      autoplay="{{ section.settings.speed }}" aria-live="polite"
    {% endif %}
  >
    {% if show_arrows %}
      {% render 'slideshow-arrows', icon_style: 'chevron' %}
    {% endif %}

    <div class="announcement-bar__slides la-story-announcement-bar__slides">
      {% content_for 'blocks' %}
    </div>
  </announcement-bar-component>
</aside>

{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  .announcement-bar__slider {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;

    @media screen and (max-width: 749px) {
      grid-column: 1 / -1;
    }
  }

  .announcement-bar__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: calc(100% - var(--button-size) * 2);
    max-width: 680px;
    margin-inline: auto;
  }

  .announcement-bar__slides > * {
    grid-area: stack;
  }

  .announcement-bar__slide {
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    content-visibility: visible;

    &[aria-hidden='true'] {
      opacity: 0;
      visibility: hidden;
    }
  }

  .announcement-bar__slider slideshow-arrows {
    padding: 0;
    mix-blend-mode: normal;
  }

  .announcement-bar__slider slideshow-arrows .slideshow-control {
    color: var(--color-foreground);
  }

  .announcement-bar__slider .slideshow-control {
    display: flex;
    padding: 0;
    width: var(--button-size);
    height: var(--button-size);
    align-items: center;
    justify-content: center;
    opacity: 1;
    animation: none;

    @media screen and (min-width: 750px) {
      --slideshow-control-offset: calc((var(--button-size) - var(--icon-size-xs)) / 2);

      .section--page-width &.slideshow-control--previous {
        transform: translateX(var(--slideshow-control-offset));
      }
    }
  }

  .announcement-bar__slider .slideshow-control .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .announcement-bar__slide {
    place-content: center;
  }

  .announcement-bar__text:first-child {
    margin: 0;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }

  /* LA STORY announcement styling */
  .la-story-announcement-bar {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(
        90deg,
        var(--la-story-announcement-bg-start) 0%,
        var(--la-story-announcement-bg-middle) 50%,
        var(--la-story-announcement-bg-end) 100%
      ) !important;
    color: var(--la-story-announcement-text);
    border-block-end: var(--border-bottom-width) solid var(--la-story-announcement-border) !important;
  }

  .la-story-announcement-bar::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 12% 50%, var(--la-story-announcement-accent), transparent 28%),
      radial-gradient(circle at 88% 50%, var(--la-story-announcement-accent), transparent 26%);
    opacity: var(--la-story-announcement-glow-opacity);
  }

  .la-story-announcement-bar::after {
    content: "";
    position: absolute;
    left: 28px;
    right: 28px;
    bottom: 0;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      transparent,
      var(--la-story-announcement-border),
      transparent
    );
  }

  .la-story-announcement-bar__slider {
    min-height: 38px;
    isolation: isolate;
  }

  .la-story-announcement-bar__slides {
    max-width: 980px;
    width: calc(100% - var(--button-size) * 2);
  }

  .la-story-announcement-bar__slider--no-controls .la-story-announcement-bar__slides {
    width: 100%;
  }

  .la-story-announcement-bar .announcement-bar__slide {
    min-height: 38px;
    display: grid;
    place-items: center;
    padding: 0 18px;
  }

  /*
    Typography is controlled by the announcement block schema.
    This section only controls layout and colors.
  */
  .la-story-announcement-bar .announcement-bar__text,
  .la-story-announcement-bar .announcement-bar__text p,
  .la-story-announcement-bar .announcement-bar__text span,
  .la-story-announcement-bar .announcement-bar__text a {
    color: inherit;
    text-align: center;
  }

  .la-story-announcement-bar .announcement-bar__text {
    margin: 0;
  }

  .la-story-announcement-bar .announcement-bar__text strong,
  .la-story-announcement-bar .announcement-bar__text b {
    color: var(--la-story-announcement-accent);
    font-weight: inherit;
  }

  .la-story-announcement-bar .announcement-bar__link {
    z-index: 2;
  }

  .la-story-announcement-bar slideshow-arrows {
    position: relative;
    z-index: 3;
  }

  .la-story-announcement-bar .slideshow-control {
    color: var(--la-story-announcement-arrow) !important;
    transition: color 0.25s ease, opacity 0.25s ease;
  }

  .la-story-announcement-bar .slideshow-control:hover {
    color: var(--la-story-announcement-arrow-hover) !important;
  }

  .la-story-announcement-bar .svg-wrapper svg {
    stroke-width: 1.5;
  }

  @media screen and (max-width: 749px) {
    .la-story-announcement-bar {
      padding-left: 0;
      padding-right: 0;
    }

    .la-story-announcement-bar::after {
      left: 16px;
      right: 16px;
    }

    .la-story-announcement-bar__slider {
      min-height: 42px;
    }

    .la-story-announcement-bar .announcement-bar__slide {
      min-height: 42px;
      padding: 0 14px;
    }

    .la-story-announcement-bar__slides {
      width: calc(100% - var(--button-size) * 2);
    }

    .la-story-announcement-bar__slider--no-controls .la-story-announcement-bar__slides {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls when multiple announcements",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "t:settings.color_scheme"
    },
    {
      "type": "color",
      "id": "background_start",
      "label": "Background start",
      "default": "#11100f"
    },
    {
      "type": "color",
      "id": "background_middle",
      "label": "Background middle",
      "default": "#211b17"
    },
    {
      "type": "color",
      "id": "background_end",
      "label": "Background end",
      "default": "#11100f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Default text color",
      "default": "#d8c3a4"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#fff6e8"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#b99a72"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#d8c3a4"
    },
    {
      "type": "color",
      "id": "arrow_hover_color",
      "label": "Arrow hover color",
      "default": "#fff6e8"
    },
    {
      "type": "range",
      "id": "glow_opacity",
      "label": "Background glow opacity",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 14
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}