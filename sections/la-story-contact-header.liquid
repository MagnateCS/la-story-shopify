{% liquid
  assign section_id = 'la-story-contact-header-' | append: section.id
%}

<section id="{{ section_id }}" class="la-story-contact-header">
  <div class="la-story-contact-header__inner">
    <header class="la-story-contact-header__content">
      {% if section.settings.eyebrow != blank %}
        <p class="la-story-contact-header__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="la-story-contact-header__heading">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="la-story-contact-header__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </header>
  </div>
</section>

<style>
  #{{ section_id }} {
    --la-story-black: #0f0f0f;
    --la-story-ink: #171717;
    --la-story-muted-light: rgba(255, 255, 255, 0.68);
    --la-story-gold: #c7a35b;

    background: var(--la-story-black);
    color: #ffffff;
    padding: 72px 24px 36px;
  }

  #{{ section_id }} .la-story-contact-header__inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  #{{ section_id }} .la-story-contact-header__content {
    max-width: 820px;
    animation: laStoryContactHeaderFadeUp-{{ section.id }} 800ms ease both;
  }

  #{{ section_id }} .la-story-contact-header__eyebrow {
    margin: 0;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 12px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.62);
  }

  #{{ section_id }} .la-story-contact-header__heading {
    margin: 18px 0 0;
    font-family: Georgia, serif;
    font-size: clamp(48px, 6vw, 78px);
    line-height: 0.95;
    font-weight: 400;
    letter-spacing: -0.05em;
    color: #ffffff;
  }

  #{{ section_id }} .la-story-contact-header__description {
    max-width: 760px;
    margin-top: 28px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 18px;
    line-height: 1.8;
    color: var(--la-story-muted-light);
  }

  @keyframes laStoryContactHeaderFadeUp-{{ section.id }} {
    from {
      opacity: 0;
      transform: translateY(28px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} {
      padding: 48px 16px 24px;
    }

    #{{ section_id }} .la-story-contact-header__description {
      font-size: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .la-story-contact-header__content {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "LA Story Contact Header",
  "tag": "section",
  "class": "section-la-story-contact-header",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Visit The Store"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Stop by the Simi Valley location, call customer service, or request a fitting using the appointment form below."
    }
  ],
  "presets": [
    {
      "name": "LA Story Contact Header"
    }
  ]
}
{% endschema %}