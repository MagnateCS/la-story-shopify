{% liquid
  assign section_id = 'la-story-hero-split-' | append: section.id
%}

<section id="{{ section_id }}" class="la-story-hero-split">
  <div class="la-story-hero-split__inner">
    <div class="la-story-hero-split__grid">
      <div class="la-story-hero-split__image-panel la-story-animate">
        {% if section.settings.hero_image != blank %}
          {{
            section.settings.hero_image
            | image_url: width: 1600
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              alt: section.settings.hero_image_alt,
              class: 'la-story-hero-split__image'
          }}
        {% else %}
          <div class="la-story-hero-split__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'la-story-hero-split__placeholder-svg' }}
          </div>
        {% endif %}

        <div class="la-story-hero-split__image-overlay"></div>

        <div class="la-story-hero-split__image-content">
          {% if section.settings.image_eyebrow != blank %}
            <p class="la-story-hero-split__image-eyebrow">
              {{ section.settings.image_eyebrow }}
            </p>
          {% endif %}

          {% if section.settings.image_heading != blank %}
            <h1 class="la-story-hero-split__image-heading">
              {{ section.settings.image_heading }}
            </h1>
          {% endif %}
        </div>
      </div>

      <div class="la-story-hero-split__content-panel la-story-animate">
        <div class="la-story-hero-split__content">
          {% if section.settings.content_eyebrow != blank %}
            <p class="la-story-hero-split__eyebrow">
              {{ section.settings.content_eyebrow }}
            </p>
          {% endif %}

          {% if section.settings.content_heading != blank %}
            <h2 class="la-story-hero-split__heading">
              {{ section.settings.content_heading }}
            </h2>
          {% endif %}

          {% if section.settings.intro_text != blank %}
            <div class="la-story-hero-split__intro">
              {{ section.settings.intro_text | newline_to_br }}
            </div>
          {% endif %}

          {% if section.settings.body_text != blank %}
            <div class="la-story-hero-split__body">
              {{ section.settings.body_text }}
            </div>
          {% endif %}

          {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
            <div class="la-story-hero-split__buttons">
              {% if section.settings.primary_button_label != blank %}
                <a
                  href="{{ section.settings.primary_button_link | default: '#' }}"
                  class="la-story-hero-split__button la-story-hero-split__button--primary"
                >
                  {{ section.settings.primary_button_label }}
                </a>
              {% endif %}

              {% if section.settings.secondary_button_label != blank %}
                <a
                  href="{{ section.settings.secondary_button_link | default: '#' }}"
                  class="la-story-hero-split__button la-story-hero-split__button--secondary"
                >
                  {{ section.settings.secondary_button_label }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    --la-story-black: #0f0f0f;
    --la-story-paper: #f6f0e6;
    --la-story-ink: #171717;
    --la-story-muted: rgba(23, 23, 23, 0.68);
    --la-story-gold: #c7a35b;
    --la-story-white-border: rgba(255, 255, 255, 0.1);
    --la-story-dark-border: rgba(23, 23, 23, 0.12);
    --la-story-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);

    background: var(--la-story-black);
    color: var(--la-story-ink);
    padding: 40px 24px;
  }

  #{{ section_id }} .la-story-hero-split__inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  #{{ section_id }} .la-story-hero-split__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  #{{ section_id }} .la-story-hero-split__image-panel,
  #{{ section_id }} .la-story-hero-split__content-panel {
    min-height: 620px;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--la-story-white-border);
    box-shadow: var(--la-story-shadow);
  }

  #{{ section_id }} .la-story-hero-split__image-panel {
    background: #1a1a1a;
  }

  #{{ section_id }} .la-story-hero-split__image,
  #{{ section_id }} .la-story-hero-split__placeholder,
  #{{ section_id }} .la-story-hero-split__placeholder-svg {
    width: 100%;
    height: 100%;
    min-height: 620px;
    display: block;
  }

  #{{ section_id }} .la-story-hero-split__image {
    object-fit: cover;
    transform: scale(1.02);
  }

  #{{ section_id }} .la-story-hero-split__placeholder {
    background: #202020;
  }

  #{{ section_id }} .la-story-hero-split__placeholder-svg {
    object-fit: cover;
    opacity: 0.35;
  }

  #{{ section_id }} .la-story-hero-split__image-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.58), rgba(0, 0, 0, 0.18) 48%, rgba(0, 0, 0, 0.5)),
      linear-gradient(90deg, rgba(0, 0, 0, 0.45), transparent 60%);
  }

  #{{ section_id }} .la-story-hero-split__image-content {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    max-width: 520px;
    padding: 40px;
  }

  #{{ section_id }} .la-story-hero-split__image-eyebrow,
  #{{ section_id }} .la-story-hero-split__eyebrow {
    margin: 0;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 12px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.35em;
  }

  #{{ section_id }} .la-story-hero-split__image-eyebrow {
    color: rgba(255, 255, 255, 0.75);
  }

  #{{ section_id }} .la-story-hero-split__image-heading {
    margin: 18px 0 0;
    font-family: Georgia, serif;
    font-size: clamp(44px, 5vw, 72px);
    line-height: 0.94;
    font-weight: 400;
    letter-spacing: -0.045em;
    color: #ffffff;
  }

  #{{ section_id }} .la-story-hero-split__content-panel {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--la-story-paper);
    border-color: var(--la-story-dark-border);
    padding: 48px;
  }

  #{{ section_id }} .la-story-hero-split__content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  #{{ section_id }} .la-story-hero-split__eyebrow {
    color: var(--la-story-muted);
  }

  #{{ section_id }} .la-story-hero-split__heading {
    margin: 22px 0 0;
    font-family: Georgia, serif;
    font-size: clamp(42px, 5vw, 68px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.045em;
    color: var(--la-story-ink);
  }

  #{{ section_id }} .la-story-hero-split__intro {
    margin-top: 32px;
    font-family: Georgia, serif;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.45;
    font-style: italic;
    color: rgba(23, 23, 23, 0.74);
  }

  #{{ section_id }} .la-story-hero-split__body {
    margin-top: 24px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 18px;
    line-height: 1.75;
    color: var(--la-story-muted);
  }

  #{{ section_id }} .la-story-hero-split__buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 40px;
  }

  #{{ section_id }} .la-story-hero-split__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 14px 28px;
    border-radius: 999px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 12px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    text-decoration: none;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  #{{ section_id }} .la-story-hero-split__button:hover {
    transform: translateY(-2px);
  }

  #{{ section_id }} .la-story-hero-split__button--primary {
    background: var(--la-story-gold);
    color: #000000;
    border: 1px solid var(--la-story-gold);
  }

  #{{ section_id }} .la-story-hero-split__button--primary:hover {
    background: #ffffff;
    border-color: #ffffff;
  }

  #{{ section_id }} .la-story-hero-split__button--secondary {
    background: transparent;
    color: var(--la-story-ink);
    border: 1px solid rgba(23, 23, 23, 0.22);
  }

  #{{ section_id }} .la-story-hero-split__button--secondary:hover {
    background: var(--la-story-ink);
    border-color: var(--la-story-ink);
    color: #ffffff;
  }

  #{{ section_id }} .la-story-animate {
    animation: laStoryFadeUp-{{ section.id }} 800ms ease both;
  }

  #{{ section_id }} .la-story-animate:nth-child(2) {
    animation-delay: 120ms;
  }

  @keyframes laStoryFadeUp-{{ section.id }} {
    from {
      opacity: 0;
      transform: translateY(28px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 989px) {
    #{{ section_id }} {
      padding: 28px 16px;
    }

    #{{ section_id }} .la-story-hero-split__grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    #{{ section_id }} .la-story-hero-split__image-panel,
    #{{ section_id }} .la-story-hero-split__content-panel {
      min-height: auto;
    }

    #{{ section_id }} .la-story-hero-split__image,
    #{{ section_id }} .la-story-hero-split__placeholder,
    #{{ section_id }} .la-story-hero-split__placeholder-svg {
      min-height: 420px;
    }

    #{{ section_id }} .la-story-hero-split__content-panel {
      padding: 42px 24px;
    }

    #{{ section_id }} .la-story-hero-split__image-content {
      padding: 28px;
    }

    #{{ section_id }} .la-story-hero-split__body {
      font-size: 16px;
    }
  }

  @media screen and (max-width: 640px) {
    #{{ section_id }} .la-story-hero-split__image-heading,
    #{{ section_id }} .la-story-hero-split__heading {
      letter-spacing: -0.035em;
    }

    #{{ section_id }} .la-story-hero-split__buttons {
      flex-direction: column;
    }

    #{{ section_id }} .la-story-hero-split__button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .la-story-animate,
    #{{ section_id }} .la-story-hero-split__button {
      animation: none;
      transition: none;
    }
  }
</style>

{% schema %}
{
  "name": "LA Story Hero Split",
  "tag": "section",
  "class": "section-la-story-hero-split",
  "settings": [
    {
      "type": "header",
      "content": "Left image panel"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Image alt text",
      "default": "Elegant fashion portrait"
    },
    {
      "type": "text",
      "id": "image_eyebrow",
      "label": "Image eyebrow text",
      "default": "Refined Atelier"
    },
    {
      "type": "textarea",
      "id": "image_heading",
      "label": "Image heading",
      "default": "Elegant pieces, tailored to feel personal."
    },
    {
      "type": "header",
      "content": "Right content panel"
    },
    {
      "type": "text",
      "id": "content_eyebrow",
      "label": "Eyebrow text",
      "default": "Welcome"
    },
    {
      "type": "textarea",
      "id": "content_heading",
      "label": "Heading",
      "default": "Designed around the woman wearing it."
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Italic intro text",
      "default": "Hello Dear!\nA woman is a creative being, the author of her own thoughts and dreams. She makes every step of her life memorable for herself and for others."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "We inspire you to think outside the box and be in control of your own destiny. There is no better day than today to feel fabulous."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Book Consultation"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "View Services"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "LA Story Hero Split"
    }
  ]
}
{% endschema %}