{% liquid
  assign section_id = 'la-story-services-header-' | append: section.id
%}

<section id="{{ section_id }}" class="la-story-services-header">
  <div class="la-story-services-header__inner">
    <header class="la-story-services-header__content">
      {% if section.settings.eyebrow != blank %}
        <p class="la-story-services-header__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="la-story-services-header__heading">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="la-story-services-header__description">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.settings.category_label != blank %}
        <p class="la-story-services-header__category">
          {{ section.settings.category_label }}
        </p>
      {% endif %}

      {% if section.settings.fee_note != blank %}
        <div class="la-story-services-header__fee-note">
          {{ section.settings.fee_note }}
        </div>
      {% endif %}
    </header>
  </div>
</section>

<style>
  #{{ section_id }} {
    --la-story-black: #0f0f0f;
    --la-story-paper: #f6f0e6;
    --la-story-ink: #171717;
    --la-story-muted: rgba(23, 23, 23, 0.68);
    --la-story-gold: #c7a35b;
    --la-story-white-border: rgba(255, 255, 255, 0.1);
    --la-story-dark-border: rgba(23, 23, 23, 0.12);

    background: var(--la-story-black);
    color: #ffffff;
    padding: 72px 24px 36px;
  }

  #{{ section_id }} .la-story-services-header__inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  #{{ section_id }} .la-story-services-header__content {
    max-width: 820px;
    animation: laStoryServicesHeaderFadeUp-{{ section.id }} 800ms ease both;
  }

  #{{ section_id }} .la-story-services-header__eyebrow {
    margin: 0;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 12px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.62);
  }

  #{{ section_id }} .la-story-services-header__heading {
    margin: 18px 0 0;
    font-family: Georgia, serif;
    font-size: clamp(48px, 6vw, 78px);
    line-height: 0.95;
    font-weight: 400;
    letter-spacing: -0.05em;
    color: #ffffff;
  }

  #{{ section_id }} .la-story-services-header__description {
    max-width: 760px;
    margin-top: 28px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 18px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.68);
  }

  #{{ section_id }} .la-story-services-header__category {
    margin: 28px 0 0;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 13px;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--la-story-gold);
  }

  #{{ section_id }} .la-story-services-header__fee-note {
    margin-top: 10px;
    font-family: Inter, Helvetica, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.62);
  }

  @keyframes laStoryServicesHeaderFadeUp-{{ section.id }} {
    from {
      opacity: 0;
      transform: translateY(28px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} {
      padding: 48px 16px 24px;
    }

    #{{ section_id }} .la-story-services-header__description {
      font-size: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .la-story-services-header__content {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "LA Story Services Header",
  "tag": "section",
  "class": "section-la-story-services-header",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Services"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Alterations & Fittings"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Service pricing below was added from the provided LA Story source page and organized into women's clothing, bridal, and formalwear sections."
    },
    {
      "type": "text",
      "id": "category_label",
      "label": "Category label",
      "default": "Women's Clothing Alterations"
    },
    {
      "type": "textarea",
      "id": "fee_note",
      "label": "Fee note",
      "default": "($5 formal/casual fitting fee; $10 bridal/restyle fitting fee)"
    }
  ],
  "presets": [
    {
      "name": "LA Story Services Header"
    }
  ]
}
{% endschema %}