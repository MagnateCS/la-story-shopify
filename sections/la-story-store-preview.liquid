        },
        {
          "type": "preview_product",
          "settings": {
            "badge": "Coming Soon",
            "title": "The Camille Gown",
            "price": "$540",
            "description": "Clean neckline with a modern fitted shape.",
            "meta": "Modern bridal · Coming soon"
          }
        },
        {
          "type": "preview_product",
          "settings": {
            "badge": "Reception",
            "title": "The Lottie Mini",
            "price": "$280",
            "description": "A little white dress for rehearsal or reception.",
            "meta": "Occasion look · Coming soon"
          }
        },
        {
          "type": "preview_product",
          "settings": {
            "badge": "Accessory",
            "title": "Pearl Veil",
            "price": "$160",
            "description": "A soft finishing piece with pearl detail.",
            "meta": "Accessory · Coming soon"
          }
        }
      ]
    }
  ]
}
{% endschema %}