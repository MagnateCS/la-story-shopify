<section class="la-story-services">
  <div class="la-story-container">
    <div class="la-story-section-header">
      <div>
        <h2>{{ section.settings.heading }}</h2>
      </div>

      <p>{{ section.settings.text }}</p>
    </div>

    <div class="la-story-services__layout">
      <div class="la-story-services__image">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              class: 'la-story-services__image-el',
              loading: 'lazy',
              alt: section.settings.image_heading
          }}
        {% endif %}

        <div class="la-story-services__image-label">
          <h3>{{ section.settings.image_heading }}</h3>
        </div>
      </div>

      <div class="la-story-services__list">
        {% for block in section.blocks %}
          <article class="la-story-service-group" {{ block.shopify_attributes }}>
            <div class="la-story-service-group__title">
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.description }}</p>
            </div>

            <div class="la-story-service-group__details">
              {% if block.settings.item_1_name != blank %}
                <div class="la-story-price-row">
                  <span><em>{{ block.settings.item_1_name }}</em></span>
                  <strong>{{ block.settings.item_1_price }}</strong>
                </div>
              {% endif %}

              {% if block.settings.item_2_name != blank %}
                <div class="la-story-price-row">
                  <span><em>{{ block.settings.item_2_name }}</em></span>
                  <strong>{{ block.settings.item_2_price }}</strong>
                </div>
              {% endif %}

              {% if block.settings.item_3_name != blank %}
                <div class="la-story-price-row">
                  <span><em>{{ block.settings.item_3_name }}</em></span>
                  <strong>{{ block.settings.item_3_price }}</strong>
                </div>
              {% endif %}

              {% if block.settings.item_4_name != blank %}
                <div class="la-story-price-row">
                  <span><em>{{ block.settings.item_4_name }}</em></span>
                  <strong>{{ block.settings.item_4_price }}</strong>
                </div>
              {% endif %}

              {% if block.settings.note != blank %}
                <p class="la-story-service-note">{{ block.settings.note }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .la-story-services {
    background: #f8f3ec;
    color: #211b17;
    padding: 92px 0;
  }

  .la-story-container {
    max-width: 1480px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  .la-story-section-header {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 60px;
    align-items: end;
    margin-bottom: 50px;
  }

  .la-story-section-header h2 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(36px, 4.2vw, 58px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  .la-story-section-header p {
    margin: 0;
    color: rgba(33, 27, 23, 0.66);
    font-size: 15px;
    line-height: 1.85;
  }

  .la-story-services__layout {
    display: grid;
    grid-template-columns: 0.86fr 1.14fr;
    gap: 28px;
    align-items: stretch;
  }

  .la-story-services__image {
    min-height: 720px;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(33, 27, 23, 0.16);
    background: #d9c7b4;
  }

  .la-story-services__image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.38), transparent 58%);
  }

  .la-story-services__image-el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .la-story-services__image-label {
    position: absolute;
    left: 30px;
    right: 30px;
    bottom: 30px;
    z-index: 2;
    color: #fff;
  }

  .la-story-services__image-label h3 {
    max-width: 520px;
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(30px, 3.5vw, 46px);
    line-height: 1;
    font-weight: 400;
    letter-spacing: -0.035em;
  }

  .la-story-services__list {
    border-top: 1px solid rgba(33, 27, 23, 0.16);
  }

  .la-story-service-group {
    display: grid;
    grid-template-columns: 0.42fr 0.58fr;
    gap: 28px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(33, 27, 23, 0.16);
  }

  .la-story-service-group__title h3 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(24px, 2.6vw, 34px);
    line-height: 1.04;
    font-weight: 400;
    letter-spacing: -0.03em;
  }

  .la-story-service-group__title p {
    margin: 12px 0 0;
    color: rgba(33, 27, 23, 0.66);
    font-size: 14px;
    line-height: 1.7;
  }

  .la-story-service-group__details {
    display: grid;
    gap: 12px;
  }

  .la-story-price-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    align-items: baseline;
    color: rgba(33, 27, 23, 0.66);
    font-size: 14px;
    line-height: 1.55;
  }

  .la-story-price-row span {
    position: relative;
    overflow: hidden;
  }

  .la-story-price-row span::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.44em;
    border-bottom: 1px dotted rgba(33, 27, 23, 0.24);
    transform: translateX(8px);
  }

  .la-story-price-row span em {
    position: relative;
    z-index: 1;
    background: #f8f3ec;
    padding-right: 8px;
    font-style: normal;
  }

  .la-story-price-row strong {
    color: #211b17;
    font-weight: 500;
    white-space: nowrap;
  }

  .la-story-service-note {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(33, 27, 23, 0.16);
    color: #877768;
    font-size: 12px;
    line-height: 1.65;
  }

  @media screen and (max-width: 1120px) {
    .la-story-services__layout {
      grid-template-columns: 1fr;
    }

    .la-story-services__image {
      min-height: 520px;
    }
  }

  @media screen and (max-width: 760px) {
    .la-story-services {
      padding: 68px 0;
    }

    .la-story-container {
      padding-left: 18px;
      padding-right: 18px;
    }

    .la-story-section-header,
    .la-story-service-group {
      grid-template-columns: 1fr;
    }

    .la-story-services__image {
      min-height: 400px;
    }
  }
</style>

